# Copy this file to `Scripts/torrentcore.env` on the target host or in the repo
# when you want to override deploy/runtime defaults without editing the scripts.

# Shared runtime environment
TORRENTCORE_ASPNETCORE_ENVIRONMENT=Production

# Runtime URLs
# Recommended default:
# - Web UI reachable from other machines on the LAN
# - Service kept local to this machine
# - Web UI talks to the local service over loopback
TORRENTCORE_SERVICE_URLS=http://127.0.0.1:7033
TORRENTCORE_WEBUI_URLS=http://0.0.0.0:7053
TORRENTCORE_WEBUI_SERVICE_BASE_URL=http://127.0.0.1:7033/

# If you also want remote API / remote Avalonia access on this host, use:
# TORRENTCORE_SERVICE_URLS=http://0.0.0.0:7033

# Avalonia app deploy targets (ARM desktop only)
# The desktop app deploy script publishes the raw output and also creates a macOS .app bundle.
# Default bundle target is ${TORRENTCORE_DEPLOY_BASE}/Applications.
# When deploying locally on the ARM host, the script also mirrors the app bundle to /Applications by default.
# To install directly into the local machine's /Applications folder, use:
# TORRENTCORE_AVALONIA_APP_TARGET=/Applications
# To control the automatic /Applications mirror, use:
# TORRENTCORE_AVALONIA_SYSTEM_APPLICATIONS_MIRROR=auto
# TORRENTCORE_AVALONIA_SYSTEM_APPLICATIONS_TARGET=/Applications
# To mirror the .app bundle to a second location, set:
# TORRENTCORE_AVALONIA_APP_MIRROR_TARGET=$HOME/Desktop
# TORRENTCORE_AVALONIA_PUBLISH_TARGET=$HOME/TorrentCore/Avalonia
# TORRENTCORE_AVALONIA_APP_TARGET=$HOME/TorrentCore/Applications
# A default TorrentCore .icns asset is now used automatically.
# To override it with a different icon, set:
# TORRENTCORE_AVALONIA_ICON_PATH=/full/path/to/CustomTorrentCore.icns

# Deploy target
TORRENTCORE_DEPLOY_BASE=/Volumes/HD-Boot-CA-Server/Users/dick/TorrentCore
TORRENTCORE_DEPLOY_BASE_INTEL=/Volumes/HD-Boot-CA-Server/Users/dick/TorrentCore
TORRENTCORE_DEPLOY_BASE_ARM=$HOME/TorrentCore

# Publish configuration
TORRENTCORE_PUBLISH_CONFIGURATION=Release
TORRENTCORE_PUBLISH_RUNTIME=osx-x64
TORRENTCORE_PUBLISH_SELF_CONTAINED=false
TORRENTCORE_PUBLISH_RUNTIME_INTEL=osx-x64
TORRENTCORE_PUBLISH_RUNTIME_ARM=osx-arm64
