@page "/torrents"
@implements IAsyncDisposable
@inject TorrentCoreClient TorrentCoreClient
@using TorrentCore.Contracts.Categories
@using TorrentCore.Contracts.Torrents

<PageTitle>Torrents</PageTitle>

<h1>Torrents</h1>

<p>Add magnets and manage active, queued, paused, completed, and errored torrents.</p>

@if (_isLoading)
{
    <p>Loading torrents...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <p>@_error</p>
}
else
{
    <section class="mb-4">
        <h2>Add Magnet</h2>

        @if (!string.IsNullOrWhiteSpace(_submitMessage))
        {
            <p>@_submitMessage</p>
        }

        <div class="mb-3">
            <label class="form-label" for="magnetUri">Magnet URI</label>
            <input id="magnetUri" class="form-control tc-break" @bind="_magnetUri" />
        </div>
        <div class="row g-3 mb-3">
            <div class="col-12 col-md-4">
                <label class="form-label" for="magnetCategory">Category</label>
                <select id="magnetCategory" class="form-select" @bind="_selectedCategoryKey">
                    <option value="">Uncategorized</option>
                    @foreach (var category in _categories.Where(category => category.Enabled).OrderBy(category => category.SortOrder).ThenBy(category => category.DisplayName, StringComparer.OrdinalIgnoreCase))
                    {
                        <option value="@category.Key">@category.DisplayName</option>
                    }
                </select>
            </div>
        </div>
        <button class="btn btn-primary" type="button" @onclick="AddMagnetAsync" disabled="@_isSubmitting">Add Torrent</button>
    </section>

    <section>
        <div class="tc-section-header mb-3">
            <h2 class="mb-0">Current Torrents</h2>
            <div class="tc-toolbar">
                <button class="btn btn-secondary" type="button" @onclick="RefreshAsync" disabled="@(_isLoading || _isSubmitting || _isBulkRunning)">Refresh</button>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-12 col-md-4">
                <label class="form-label" for="torrentNameFilter">Name Filter</label>
                <input id="torrentNameFilter"
                       class="form-control"
                       placeholder="Filter by name"
                       @bind="_nameFilter"
                       @bind:event="oninput" />
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label" for="torrentStatusFilter">Status Filter</label>
                <select id="torrentStatusFilter" class="form-select" @bind="_statusFilter">
                    <option value="">All</option>
                    @foreach (var state in Enum.GetValues<TorrentState>())
                    {
                        <option value="@state.ToString()">@state</option>
                    }
                </select>
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label" for="torrentCategoryFilter">Category Filter</label>
                <select id="torrentCategoryFilter" class="form-select" @bind="_categoryFilter">
                    <option value="">All</option>
                    <option value="@UncategorizedFilterValue">Uncategorized</option>
                    @foreach (var category in _categories.OrderBy(category => category.SortOrder).ThenBy(category => category.DisplayName, StringComparer.OrdinalIgnoreCase))
                    {
                        <option value="@category.Key">@category.DisplayName</option>
                    }
                </select>
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label" for="torrentCallbackFilter">Callback Filter</label>
                <select id="torrentCallbackFilter" class="form-select" @bind="_callbackStateFilter">
                    <option value="">All</option>
                    <option value="PendingFinalization">PendingFinalization</option>
                    <option value="Invoked">Invoked</option>
                    <option value="Failed">Failed</option>
                    <option value="TimedOut">TimedOut</option>
                </select>
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label" for="torrentSort">Sort</label>
                <select id="torrentSort" class="form-select" @bind="_sortOption">
                    <option value="@TorrentSortOption.Name">Name</option>
                    <option value="@TorrentSortOption.State">State</option>
                    <option value="@TorrentSortOption.ProgressDescending">Progress (High to Low)</option>
                    <option value="@TorrentSortOption.AddedNewest">Added (Newest)</option>
                </select>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_actionMessage))
        {
            <p>@_actionMessage</p>
        }

        <div class="tc-toolbar mb-3">
            <button class="btn btn-outline-secondary"
                    type="button"
                    @onclick="PauseSelectedAsync"
                    disabled="@(_isLoading || _isSubmitting || _isBulkRunning || SelectedTorrentCount == 0)">
                Pause Selected
            </button>
            <button class="btn btn-outline-secondary"
                    type="button"
                    @onclick="ResumeSelectedAsync"
                    disabled="@(_isLoading || _isSubmitting || _isBulkRunning || SelectedTorrentCount == 0)">
                Resume Selected
            </button>
            <button class="btn btn-outline-danger"
                    type="button"
                    @onclick="RemoveSelectedAsync"
                    disabled="@(_isLoading || _isSubmitting || _isBulkRunning || SelectedTorrentCount == 0)">
                Remove Selected
            </button>
            <button class="btn btn-outline-secondary"
                    type="button"
                    @onclick="ToggleVisibleSelection"
                    disabled="@(_isLoading || _isBulkRunning || VisibleTorrents.Count == 0)">
                @(AreAllVisibleSelected ? "Clear Visible" : "Select Visible")
            </button>
            <button class="btn btn-outline-secondary"
                    type="button"
                    @onclick="ClearSelection"
                    disabled="@(SelectedTorrentCount == 0 || _isBulkRunning)">
                Clear Selection
            </button>
            <span class="align-self-center text-muted">Selected: @SelectedTorrentCount</span>
        </div>

        @if (VisibleTorrents.Count == 0)
        {
            <p>No torrents matched the current filters.</p>
        }
        else
        {
            <div class="tc-table-wrap d-none d-md-block">
                <table class="table align-middle">
                    <thead>
                    <tr>
                        <th>
                            <input type="checkbox"
                                   checked="@AreAllVisibleSelected"
                                   @onchange="ToggleSelectAllVisible" />
                        </th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Wait</th>
                        <th>Progress</th>
                        <th>Down</th>
                        <th>Up</th>
                        <th>Trackers</th>
                        <th>Peers</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var torrent in VisibleTorrents)
                    {
                        <tr>
                            <td>
                                <input type="checkbox"
                                       checked="@IsSelected(torrent.TorrentId)"
                                       @onchange="args => ToggleSelection(torrent.TorrentId, args.Value)" />
                            </td>
                            <td><a class="tc-break" href="@($"/torrents/{torrent.TorrentId:D}")">@torrent.Name</a></td>
                            <td>@FormatCategory(torrent.CategoryKey)</td>
                            <td>
                                <div>@torrent.State</div>
                                <div class="small text-muted">Callback: @FormatCompletionCallbackState(torrent.CompletionCallbackState, torrent.CompletedAtUtc)</div>
                            </td>
                            <td>@FormatWaitReason(torrent)</td>
                            <td>@torrent.ProgressPercent.ToString("0.0")%</td>
                            <td>@FormatRate(torrent.DownloadRateBytesPerSecond)</td>
                            <td>@FormatRate(torrent.UploadRateBytesPerSecond)</td>
                            <td>@torrent.TrackerCount</td>
                            <td>@torrent.ConnectedPeerCount</td>
                            <td>
                                @RenderTorrentActions(torrent)
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="d-md-none tc-card-list">
                @foreach (var torrent in VisibleTorrents)
                {
                    <article class="tc-mobile-card">
                        <div class="tc-mobile-card-header">
                            <label class="d-flex align-items-start gap-2 mb-0">
                                <input type="checkbox"
                                       class="mt-1"
                                       checked="@IsSelected(torrent.TorrentId)"
                                       @onchange="args => ToggleSelection(torrent.TorrentId, args.Value)" />
                                <span>
                                    <a class="fw-semibold tc-break d-block" href="@($"/torrents/{torrent.TorrentId:D}")">@torrent.Name</a>
                                    <small class="text-muted">@FormatCategory(torrent.CategoryKey) · @torrent.State</small>
                                    <small class="text-muted d-block">Callback: @FormatCompletionCallbackState(torrent.CompletionCallbackState, torrent.CompletedAtUtc)</small>
                                </span>
                            </label>
                        </div>

                        <dl class="tc-mobile-definition-list mb-3">
                            <dt>Wait</dt>
                            <dd>@FormatWaitReason(torrent)</dd>
                            <dt>Progress</dt>
                            <dd>@torrent.ProgressPercent.ToString("0.0")%</dd>
                            <dt>Download</dt>
                            <dd>@FormatRate(torrent.DownloadRateBytesPerSecond)</dd>
                            <dt>Upload</dt>
                            <dd>@FormatRate(torrent.UploadRateBytesPerSecond)</dd>
                            <dt>Trackers</dt>
                            <dd>@torrent.TrackerCount</dd>
                            <dt>Peers</dt>
                            <dd>@torrent.ConnectedPeerCount</dd>
                        </dl>

                        @RenderTorrentActions(torrent)
                    </article>
                }
            </div>
        }
    </section>
}

@code {
    private IReadOnlyList<TorrentSummaryDto> _torrents = Array.Empty<TorrentSummaryDto>();
    private IReadOnlyList<TorrentCategoryDto> _categories = Array.Empty<TorrentCategoryDto>();
    private string? _error;
    private string? _submitMessage;
    private string? _actionMessage;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private bool _isBulkRunning;
    private string _magnetUri = "magnet:?xt=urn:btih:1234567890ABCDEF1234567890ABCDEF12345678&dn=Phase%200%20Sample";
    private string _selectedCategoryKey = string.Empty;
    private string _nameFilter = string.Empty;
    private string _statusFilter = string.Empty;
    private string _categoryFilter = string.Empty;
    private string _callbackStateFilter = string.Empty;
    private TorrentSortOption _sortOption = TorrentSortOption.AddedNewest;
    private readonly HashSet<Guid> _busyTorrentIds = [];
    private readonly HashSet<Guid> _selectedTorrentIds = [];
    private readonly SemaphoreSlim _loadGate = new(1, 1);
    private CancellationTokenSource? _refreshLoopCts;
    private Task? _refreshLoopTask;
    private bool _isDisposed;
    private bool _categorySelectionInitialized;

    private IReadOnlyList<TorrentSummaryDto> VisibleTorrents =>
        ApplySort(
            _torrents
                .Where(MatchesNameFilter)
                .Where(MatchesStatusFilter)
                .Where(MatchesCategoryFilter)
                .Where(MatchesCallbackStateFilter)
                .ToArray())
        .ToArray();

    private int SelectedTorrentCount => _selectedTorrentIds.Count;

    private bool AreAllVisibleSelected =>
        VisibleTorrents.Count > 0 && VisibleTorrents.All(torrent => _selectedTorrentIds.Contains(torrent.TorrentId));

    private const string UncategorizedFilterValue = "__uncategorized";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _refreshLoopCts = new CancellationTokenSource();
        _refreshLoopTask = RunRefreshLoopAsync(_refreshLoopCts.Token);
    }

    private async Task LoadAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        await _loadGate.WaitAsync();

        try
        {
            if (_isDisposed)
            {
                return;
            }

            _error = null;
            var categoriesTask = TorrentCoreClient.GetCategoriesAsync();
            var torrentsTask = TorrentCoreClient.GetTorrentsAsync();
            await Task.WhenAll(categoriesTask, torrentsTask);
            _categories = categoriesTask.Result;
            _torrents = torrentsTask.Result;
            if (!_categorySelectionInitialized)
            {
                _selectedCategoryKey = ResolveDefaultAddCategoryKey();
                _categorySelectionInitialized = true;
            }
            else if (!string.IsNullOrWhiteSpace(_selectedCategoryKey) && !CategoryIsSelectable(_selectedCategoryKey))
            {
                _selectedCategoryKey = ResolveDefaultAddCategoryKey();
            }

            _selectedTorrentIds.RemoveWhere(torrentId => _torrents.All(torrent => torrent.TorrentId != torrentId));
        }
        catch (Exception exception)
        {
            _error = $"Unable to reach TorrentCore service: {exception.Message}";
        }
        finally
        {
            _isLoading = false;
            _loadGate.Release();
        }
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
    }

    private async Task AddMagnetAsync()
    {
        _isSubmitting = true;
        _submitMessage = null;
        _actionMessage = null;

        try
        {
            var torrent = await TorrentCoreClient.AddMagnetAsync(new AddMagnetRequest
            {
                MagnetUri = _magnetUri,
                CategoryKey = string.IsNullOrWhiteSpace(_selectedCategoryKey) ? null : _selectedCategoryKey,
            });

            _submitMessage = $"Added torrent '{torrent.Name}' in state '{torrent.State}'.";
            _magnetUri = string.Empty;
            _selectedCategoryKey = ResolveDefaultAddCategoryKey();
            await LoadAsync();
        }
        catch (TorrentCoreClientException exception)
        {
            _submitMessage = exception.ServiceError?.Message ?? exception.Message;
        }
        catch (Exception exception)
        {
            _submitMessage = $"Unable to add torrent: {exception.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static string FormatRate(long bytesPerSecond) =>
        $"{bytesPerSecond / 1_000_000.0:0.00} MB/s";

    private static string FormatWaitReason(TorrentSummaryDto torrent)
    {
        var waitReason = torrent.WaitReason switch
        {
            TorrentWaitReason.PendingMetadataDispatch => "Pending metadata dispatch",
            TorrentWaitReason.WaitingForMetadataSlot => "Waiting for metadata slot",
            TorrentWaitReason.PendingDownloadDispatch => "Pending download dispatch",
            TorrentWaitReason.WaitingForDownloadSlot => "Waiting for download slot",
            TorrentWaitReason.PausedByOperator => "Paused by operator",
            TorrentWaitReason.BlockedByError => "Blocked by error",
            _ => string.Empty,
        };

        return torrent.QueuePosition is null || string.IsNullOrWhiteSpace(waitReason)
            ? waitReason
            : $"{waitReason} (#{torrent.QueuePosition.Value})";
    }

    private static string FormatCompletionCallbackState(string? state, DateTimeOffset? completedAtUtc) =>
        !string.IsNullOrWhiteSpace(state)
            ? state
            : completedAtUtc is null
                ? "Waiting for completion"
                : "Not requested";

    private string ResolveDefaultAddCategoryKey()
    {
        var tvCategory = _categories.FirstOrDefault(category =>
            category.Enabled &&
            string.Equals(category.Key, "TV", StringComparison.OrdinalIgnoreCase));

        return tvCategory?.Key ?? string.Empty;
    }

    private bool CategoryIsSelectable(string categoryKey) =>
        _categories.Any(category =>
            category.Enabled &&
            string.Equals(category.Key, categoryKey, StringComparison.OrdinalIgnoreCase));

    private async Task PauseAsync(TorrentSummaryDto torrent)
    {
        await RunTorrentActionAsync(
            torrent.TorrentId,
            async () =>
            {
                var result = await TorrentCoreClient.PauseAsync(torrent.TorrentId);
                _actionMessage = $"Paused torrent '{torrent.Name}' at {result.ProcessedAtUtc.ToLocalTime():g}.";
            });
    }

    private async Task ResumeAsync(TorrentSummaryDto torrent)
    {
        await RunTorrentActionAsync(
            torrent.TorrentId,
            async () =>
            {
                var result = await TorrentCoreClient.ResumeAsync(torrent.TorrentId);
                _actionMessage = $"Resumed torrent '{torrent.Name}' at {result.ProcessedAtUtc.ToLocalTime():g}.";
            });
    }

    private async Task RetryCompletionCallbackAsync(TorrentSummaryDto torrent)
    {
        await RunTorrentActionAsync(
            torrent.TorrentId,
            async () =>
            {
                var result = await TorrentCoreClient.RetryCompletionCallbackAsync(torrent.TorrentId);
                _actionMessage = $"Queued completion callback retry for '{torrent.Name}' at {result.ProcessedAtUtc.ToLocalTime():g}.";
            });
    }

    private async Task RemoveAsync(TorrentSummaryDto torrent, bool deleteData)
    {
        await RunTorrentActionAsync(
            torrent.TorrentId,
            async () =>
            {
                var result = await TorrentCoreClient.RemoveAsync(torrent.TorrentId, new RemoveTorrentRequest
                {
                    DeleteData = deleteData,
                });

                _actionMessage = deleteData
                    ? $"Removed torrent '{torrent.Name}' and requested data deletion at {result.ProcessedAtUtc.ToLocalTime():g}."
                    : $"Removed torrent '{torrent.Name}' from TorrentCore tracking at {result.ProcessedAtUtc.ToLocalTime():g}.";
            });
    }

    private async Task RunTorrentActionAsync(Guid torrentId, Func<Task> action)
    {
        if (!_busyTorrentIds.Add(torrentId))
        {
            return;
        }

        _submitMessage = null;

        try
        {
            await action();
            await LoadAsync();
        }
        catch (TorrentCoreClientException exception)
        {
            _actionMessage = exception.ServiceError?.Message ?? exception.Message;
        }
        catch (Exception exception)
        {
            _actionMessage = $"Torrent action failed: {exception.Message}";
        }
        finally
        {
            _busyTorrentIds.Remove(torrentId);
        }
    }

    private bool IsActionBusy(Guid torrentId) => _busyTorrentIds.Contains(torrentId);

    private bool IsSelected(Guid torrentId) => _selectedTorrentIds.Contains(torrentId);

    private void ToggleSelection(Guid torrentId, object? value)
    {
        var isSelected = ParseCheckboxValue(value);
        if (isSelected)
        {
            _selectedTorrentIds.Add(torrentId);
        }
        else
        {
            _selectedTorrentIds.Remove(torrentId);
        }
    }

    private void ToggleSelectAllVisible(ChangeEventArgs args)
    {
        var isSelected = ParseCheckboxValue(args.Value);

        foreach (var torrent in VisibleTorrents)
        {
            if (isSelected)
            {
                _selectedTorrentIds.Add(torrent.TorrentId);
            }
            else
            {
                _selectedTorrentIds.Remove(torrent.TorrentId);
            }
        }
    }

    private void ToggleVisibleSelection()
    {
        var clearVisible = AreAllVisibleSelected;

        foreach (var torrent in VisibleTorrents)
        {
            if (clearVisible)
            {
                _selectedTorrentIds.Remove(torrent.TorrentId);
            }
            else
            {
                _selectedTorrentIds.Add(torrent.TorrentId);
            }
        }
    }

    private void ClearSelection()
    {
        _selectedTorrentIds.Clear();
    }

    private bool MatchesNameFilter(TorrentSummaryDto torrent) =>
        string.IsNullOrWhiteSpace(_nameFilter) ||
        torrent.Name.Contains(_nameFilter, StringComparison.OrdinalIgnoreCase);

    private bool MatchesStatusFilter(TorrentSummaryDto torrent) =>
        string.IsNullOrWhiteSpace(_statusFilter) ||
        string.Equals(torrent.State.ToString(), _statusFilter, StringComparison.OrdinalIgnoreCase);

    private bool MatchesCategoryFilter(TorrentSummaryDto torrent) =>
        string.IsNullOrWhiteSpace(_categoryFilter) ||
        (_categoryFilter == UncategorizedFilterValue
            ? string.IsNullOrWhiteSpace(torrent.CategoryKey)
            : string.Equals(torrent.CategoryKey, _categoryFilter, StringComparison.OrdinalIgnoreCase));

    private bool MatchesCallbackStateFilter(TorrentSummaryDto torrent) =>
        string.IsNullOrWhiteSpace(_callbackStateFilter) ||
        string.Equals(torrent.CompletionCallbackState, _callbackStateFilter, StringComparison.OrdinalIgnoreCase);

    private IEnumerable<TorrentSummaryDto> ApplySort(IEnumerable<TorrentSummaryDto> torrents)
    {
        return _sortOption switch
        {
            TorrentSortOption.Name => torrents.OrderBy(torrent => torrent.Name, StringComparer.OrdinalIgnoreCase),
            TorrentSortOption.State => torrents.OrderBy(torrent => torrent.State.ToString(), StringComparer.OrdinalIgnoreCase)
                .ThenBy(torrent => torrent.Name, StringComparer.OrdinalIgnoreCase),
            TorrentSortOption.ProgressDescending => torrents.OrderByDescending(torrent => torrent.ProgressPercent)
                .ThenBy(torrent => torrent.Name, StringComparer.OrdinalIgnoreCase),
            _ => torrents.OrderByDescending(torrent => torrent.AddedAtUtc)
                .ThenBy(torrent => torrent.Name, StringComparer.OrdinalIgnoreCase),
        };
    }

    private static bool CanDeleteData(TorrentSummaryDto torrent) =>
        torrent.State is TorrentState.ResolvingMetadata or TorrentState.Queued or TorrentState.Downloading or TorrentState.Error or TorrentState.Paused;

    private async Task PauseSelectedAsync()
    {
        var selectedTorrents = _torrents.Where(torrent => _selectedTorrentIds.Contains(torrent.TorrentId)).ToArray();
        await RunBulkActionAsync(
            selectedTorrents,
            torrent => torrent.CanPause,
            torrent => TorrentCoreClient.PauseAsync(torrent.TorrentId),
            "Pause selected");
    }

    private async Task ResumeSelectedAsync()
    {
        var selectedTorrents = _torrents.Where(torrent => _selectedTorrentIds.Contains(torrent.TorrentId)).ToArray();
        await RunBulkActionAsync(
            selectedTorrents,
            torrent => torrent.CanResume,
            torrent => TorrentCoreClient.ResumeAsync(torrent.TorrentId),
            "Resume selected");
    }

    private async Task RemoveSelectedAsync()
    {
        var selectedTorrents = _torrents.Where(torrent => _selectedTorrentIds.Contains(torrent.TorrentId)).ToArray();
        await RunBulkActionAsync(
            selectedTorrents,
            torrent => torrent.CanRemove,
            torrent => TorrentCoreClient.RemoveAsync(torrent.TorrentId, new RemoveTorrentRequest { DeleteData = false }),
            "Remove selected");
    }

    private async Task RunBulkActionAsync(
        IEnumerable<TorrentSummaryDto> torrents,
        Func<TorrentSummaryDto, bool> predicate,
        Func<TorrentSummaryDto, Task<TorrentActionResultDto>> action,
        string label)
    {
        var candidates = torrents.Where(predicate).ToArray();
        if (candidates.Length == 0)
        {
            _actionMessage = $"{label}: no eligible torrents.";
            return;
        }

        _isBulkRunning = true;
        _submitMessage = null;
        _actionMessage = null;

        var successCount = 0;
        var failureCount = 0;
        var failureMessages = new List<string>();

        foreach (var torrent in candidates)
        {
            if (!_busyTorrentIds.Add(torrent.TorrentId))
            {
                continue;
            }

            try
            {
                await action(torrent);
                successCount++;
            }
            catch (TorrentCoreClientException exception)
            {
                failureCount++;
                failureMessages.Add($"{torrent.Name}: {exception.ServiceError?.Message ?? exception.Message}");
            }
            catch (Exception exception)
            {
                failureCount++;
                failureMessages.Add($"{torrent.Name}: {exception.Message}");
            }
            finally
            {
                _busyTorrentIds.Remove(torrent.TorrentId);
            }
        }

        await LoadAsync();
        _selectedTorrentIds.RemoveWhere(torrentId => _torrents.All(torrent => torrent.TorrentId != torrentId));

        _actionMessage = failureCount == 0
            ? $"{label}: {successCount} torrent(s) processed."
            : $"{label}: {successCount} succeeded, {failureCount} failed. {string.Join(" | ", failureMessages.Take(3))}";

        _isBulkRunning = false;
    }

    private static bool ParseCheckboxValue(object? value) =>
        value switch
        {
            bool boolValue => boolValue,
            string stringValue when bool.TryParse(stringValue, out var parsed) => parsed,
            string stringValue when string.Equals(stringValue, "on", StringComparison.OrdinalIgnoreCase) => true,
            _ => false,
        };

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));

        while (await timer.WaitForNextTickAsync(cancellationToken))
        {
            if (_isSubmitting || _isBulkRunning || _busyTorrentIds.Count > 0)
            {
                continue;
            }

            await InvokeAsync(async () =>
            {
                if (_isDisposed)
                {
                    return;
                }

                await LoadAsync();
                StateHasChanged();
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;

        if (_refreshLoopCts is not null)
        {
            await _refreshLoopCts.CancelAsync();
            _refreshLoopCts.Dispose();
        }

        if (_refreshLoopTask is not null)
        {
            try
            {
                await _refreshLoopTask;
            }
            catch (OperationCanceledException)
            {
            }
        }
    }

    private enum TorrentSortOption
    {
        Name,
        State,
        ProgressDescending,
        AddedNewest,
    }

    private static string FormatCategory(string? categoryKey) =>
        string.IsNullOrWhiteSpace(categoryKey) ? "Uncategorized" : categoryKey;

    private RenderFragment RenderTorrentActions(TorrentSummaryDto torrent) => @<div class="tc-toolbar">
        @if (torrent.CanPause)
        {
            <button class="btn btn-sm btn-outline-secondary"
                    type="button"
                    @onclick="() => PauseAsync(torrent)"
                    disabled="@IsActionBusy(torrent.TorrentId)">
                Pause
            </button>
        }
        @if (torrent.CanResume)
        {
            <button class="btn btn-sm btn-outline-secondary"
                    type="button"
                    @onclick="() => ResumeAsync(torrent)"
                    disabled="@IsActionBusy(torrent.TorrentId)">
                Resume
            </button>
        }
        @if (torrent.CanRetryCompletionCallback)
        {
            <button class="btn btn-sm btn-outline-secondary"
                    type="button"
                    @onclick="() => RetryCompletionCallbackAsync(torrent)"
                    disabled="@IsActionBusy(torrent.TorrentId)">
                Retry Callback
            </button>
        }
        @if (torrent.CanRemove)
        {
            <a class="btn btn-sm btn-outline-primary"
               href="@($"/torrents/{torrent.TorrentId:D}")">
                Details
            </a>
            <button class="btn btn-sm btn-outline-danger"
                    type="button"
                    @onclick="() => RemoveAsync(torrent, deleteData: false)"
                    disabled="@IsActionBusy(torrent.TorrentId)">
                Remove
            </button>
            @if (CanDeleteData(torrent))
            {
                <button class="btn btn-sm btn-danger"
                        type="button"
                        @onclick="() => RemoveAsync(torrent, deleteData: true)"
                        disabled="@IsActionBusy(torrent.TorrentId)">
                    Delete Data
                </button>
            }
        }
    </div>;
}
