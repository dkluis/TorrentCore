@page "/"
@inject TorrentCoreClient TorrentCoreClient
@using TorrentCore.Contracts.Host
@using TorrentCore.Contracts.Torrents

<PageTitle>TorrentCore</PageTitle>

<h1>TorrentCore</h1>

<p>Standalone torrent engine admin surface.</p>

@if (_isLoading)
{
    <p>Loading host status and torrent list...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <p>@_error</p>
}
else
{
    if (_hostStatus is not null)
    {
        <section>
            <h2>Host Status</h2>
            <p>Status: @_hostStatus.Status</p>
            <p>Service: @_hostStatus.ServiceName</p>
            <p>Version: @_hostStatus.ServiceVersion</p>
            <p>Service Instance: @_hostStatus.ServiceInstanceId</p>
            <p>Environment: @_hostStatus.EnvironmentName</p>
            <p>Download Root: @_hostStatus.DownloadRootPath</p>
            <p>Torrents: @_hostStatus.TorrentCount</p>
            <p>Persistent Storage: @_hostStatus.SupportsPersistentStorage</p>
            <p>Startup Recovery Complete: @_hostStatus.StartupRecoveryCompleted</p>
            <p>Recovered at Startup: @_hostStatus.StartupRecoveredTorrentCount</p>
            <p>Normalized at Startup: @_hostStatus.StartupNormalizedTorrentCount</p>
            @if (_hostStatus.StartupRecoveryCompletedAtUtc is not null)
            {
                <p>Recovery Completed: @_hostStatus.StartupRecoveryCompletedAtUtc.Value.ToLocalTime()</p>
            }
            <p>Checked: @_hostStatus.CheckedAtUtc.ToLocalTime()</p>
        </section>
    }

    <section>
        <h2>Add Magnet</h2>

        @if (!string.IsNullOrWhiteSpace(_submitMessage))
        {
            <p>@_submitMessage</p>
        }

        <div class="mb-3">
            <label class="form-label" for="magnetUri">Magnet URI</label>
            <input id="magnetUri" class="form-control" @bind="_magnetUri" />
        </div>
        <button class="btn btn-primary" @onclick="AddMagnetAsync" disabled="@_isSubmitting">Add Torrent</button>
    </section>

    <section class="mt-4">
        <h2>Current Torrents</h2>

        @if (_torrents.Count == 0)
        {
            <p>No torrents are currently tracked on this host.</p>
        }
        else
        {
            <table class="table">
                <thead>
                <tr>
                    <th>Name</th>
                    <th>Status</th>
                    <th>Progress</th>
                    <th>Down</th>
                    <th>Up</th>
                    <th>Trackers</th>
                    <th>Peers</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var torrent in _torrents)
                {
                    <tr>
                        <td>@torrent.Name</td>
                        <td>@torrent.State</td>
                        <td>@torrent.ProgressPercent.ToString("0.0")%</td>
                        <td>@FormatRate(torrent.DownloadRateBytesPerSecond)</td>
                        <td>@FormatRate(torrent.UploadRateBytesPerSecond)</td>
                        <td>@torrent.TrackerCount</td>
                        <td>@torrent.ConnectedPeerCount</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>
}

<section>
    <h2>Current Boundary</h2>
    <ul>
        <li>TorrentCore owns the engine, API, persistence, and full admin UI.</li>
        <li>TVMaze stays a lightweight client and does not own TorrentCore internals.</li>
        <li>The first rich admin UI is Web. Avalonia can be added later if still needed.</li>
    </ul>
</section>

<section>
    <h2>Next Work</h2>
    <ul>
        <li>Replace the managed fake runtime with a real MonoTorrent-backed runtime.</li>
        <li>Expand torrent runtime details and recovery behavior behind the existing API boundary.</li>
        <li>Add richer diagnostics and operational views in the web UI.</li>
    </ul>
</section>

@code {
    private EngineHostStatusDto? _hostStatus;
    private IReadOnlyList<TorrentSummaryDto> _torrents = Array.Empty<TorrentSummaryDto>();
    private string? _error;
    private string? _submitMessage;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private string _magnetUri = "magnet:?xt=urn:btih:1234567890ABCDEF1234567890ABCDEF12345678&dn=Phase%200%20Sample";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _error = null;
            _hostStatus = await TorrentCoreClient.GetHostStatusAsync();
            _torrents = await TorrentCoreClient.GetTorrentsAsync();
        }
        catch (Exception ex)
        {
            _error = $"Unable to reach TorrentCore service: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddMagnetAsync()
    {
        _isSubmitting = true;
        _submitMessage = null;

        try
        {
            var torrent = await TorrentCoreClient.AddMagnetAsync(new AddMagnetRequest
            {
                MagnetUri = _magnetUri,
            });

            _submitMessage = $"Added torrent '{torrent.Name}' in state '{torrent.State}'.";
            _magnetUri = string.Empty;
            await LoadAsync();
        }
        catch (TorrentCoreClientException ex)
        {
            _submitMessage = ex.ServiceError?.Message ?? ex.Message;
        }
        catch (Exception ex)
        {
            _submitMessage = $"Unable to add torrent: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static string FormatRate(long bytesPerSecond)
    {
        return $"{bytesPerSecond / 1_000_000.0:0.00} MB/s";
    }
}
