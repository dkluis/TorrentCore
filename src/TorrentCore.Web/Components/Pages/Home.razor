@page "/"
@implements IAsyncDisposable
@inject TorrentCoreClient TorrentCoreClient
@using TorrentCore.Contracts.Host

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

<p>Host health, engine saturation, and runtime policy summary.</p>

@if (_isLoading)
{
    <p>Loading host status...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <p>@_error</p>
}
else if (_hostStatus is not null)
{
    <section class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">Host Status</h2>
            <button class="btn btn-secondary" @onclick="RefreshAsync" disabled="@_isLoading">Refresh</button>
        </div>

        <div class="row g-3">
            <div class="col-xl-3 col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 card-title">Service</h3>
                        <p class="mb-1"><strong>Status:</strong> @_hostStatus.Status</p>
                        <p class="mb-1"><strong>Service:</strong> @_hostStatus.ServiceName</p>
                        <p class="mb-1"><strong>Version:</strong> @_hostStatus.ServiceVersion</p>
                        <p class="mb-1"><strong>Environment:</strong> @_hostStatus.EnvironmentName</p>
                        <p class="mb-1"><strong>Service Instance:</strong> @_hostStatus.ServiceInstanceId</p>
                        <p class="mb-0"><strong>Checked:</strong> @_hostStatus.CheckedAtUtc.ToLocalTime()</p>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 card-title">Engine</h3>
                        <p class="mb-1"><strong>Runtime:</strong> @_hostStatus.EngineRuntime</p>
                        <p class="mb-1"><strong>Listen Port:</strong> @_hostStatus.EngineListenPort</p>
                        <p class="mb-1"><strong>DHT Port:</strong> @_hostStatus.EngineDhtPort</p>
                        <p class="mb-1"><strong>Port Forwarding:</strong> @_hostStatus.EnginePortForwardingEnabled</p>
                        <p class="mb-1"><strong>Local Peer Discovery:</strong> @_hostStatus.EngineLocalPeerDiscoveryEnabled</p>
                        <p class="mb-1"><strong>Max Connections:</strong> @_hostStatus.EngineMaximumConnections</p>
                        <p class="mb-1"><strong>Max Half-Open:</strong> @_hostStatus.EngineMaximumHalfOpenConnections</p>
                        <p class="mb-1"><strong>Connected Peers:</strong> @_hostStatus.CurrentConnectedPeerCount</p>
                        <p class="mb-1"><strong>Current Download:</strong> @FormatRate(_hostStatus.CurrentDownloadRateBytesPerSecond)</p>
                        <p class="mb-1"><strong>Current Upload:</strong> @FormatRate(_hostStatus.CurrentUploadRateBytesPerSecond)</p>
                        <p class="mb-1"><strong>Max Download:</strong> @FormatRateLimit(_hostStatus.EngineMaximumDownloadRateBytesPerSecond)</p>
                        <p class="mb-0"><strong>Max Upload:</strong> @FormatRateLimit(_hostStatus.EngineMaximumUploadRateBytesPerSecond)</p>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 card-title">Queue And Activity</h3>
                        <p class="mb-1"><strong>Total Torrents:</strong> @_hostStatus.TorrentCount</p>
                        <p class="mb-1"><strong>Max Metadata Slots:</strong> @_hostStatus.MaxActiveMetadataResolutions</p>
                        <p class="mb-1"><strong>Max Download Slots:</strong> @_hostStatus.MaxActiveDownloads</p>
                        <p class="mb-1"><strong>Open Metadata Slots:</strong> @_hostStatus.AvailableMetadataResolutionSlots</p>
                        <p class="mb-1"><strong>Open Download Slots:</strong> @_hostStatus.AvailableDownloadSlots</p>
                        <p class="mb-1"><strong>Resolving Metadata:</strong> @_hostStatus.ResolvingMetadataCount</p>
                        <p class="mb-1"><strong>Queued For Metadata:</strong> @_hostStatus.MetadataQueueCount</p>
                        <p class="mb-1"><strong>Downloading:</strong> @_hostStatus.DownloadingCount</p>
                        <p class="mb-1"><strong>Queued For Download:</strong> @_hostStatus.DownloadQueueCount</p>
                        <p class="mb-1"><strong>Seeding:</strong> @_hostStatus.SeedingCount</p>
                        <p class="mb-1"><strong>Paused:</strong> @_hostStatus.PausedCount</p>
                        <p class="mb-1"><strong>Completed:</strong> @_hostStatus.CompletedCount</p>
                        <p class="mb-0"><strong>Error:</strong> @_hostStatus.ErrorCount</p>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 card-title">Policies And Storage</h3>
                        <p class="mb-1"><strong>Partial Files:</strong> @(_hostStatus.PartialFilesEnabled ? "Enabled" : "Disabled")</p>
                        <p class="mb-1"><strong>Partial Suffix:</strong> @_hostStatus.PartialFileSuffix</p>
                        <p class="mb-1"><strong>Seeding Mode:</strong> @_hostStatus.SeedingStopMode</p>
                        <p class="mb-1"><strong>Seeding Ratio:</strong> @_hostStatus.SeedingStopRatio.ToString("0.00")</p>
                        <p class="mb-1"><strong>Seeding Minutes:</strong> @_hostStatus.SeedingStopMinutes</p>
                        <p class="mb-1"><strong>Cleanup Mode:</strong> @_hostStatus.CompletedTorrentCleanupMode</p>
                        <p class="mb-1"><strong>Cleanup Minutes:</strong> @_hostStatus.CompletedTorrentCleanupMinutes</p>
                        <p class="mb-1"><strong>Persistent Storage:</strong> @_hostStatus.SupportsPersistentStorage</p>
                        <p class="mb-1"><strong>Startup Recovery:</strong> @_hostStatus.StartupRecoveryCompleted</p>
                        <p class="mb-1"><strong>Recovered At Startup:</strong> @_hostStatus.StartupRecoveredTorrentCount</p>
                        <p class="mb-1"><strong>Normalized At Startup:</strong> @_hostStatus.StartupNormalizedTorrentCount</p>
                        @if (_hostStatus.StartupRecoveryCompletedAtUtc is not null)
                        {
                            <p class="mb-1"><strong>Recovery Completed:</strong> @_hostStatus.StartupRecoveryCompletedAtUtc.Value.ToLocalTime()</p>
                        }
                        <p class="mb-0"><strong>Download Root:</strong> @_hostStatus.DownloadRootPath</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<section class="mb-4">
    <h2>Current Boundary</h2>
    <ul>
        <li>TorrentCore owns the engine, queueing, persistence, diagnostics, and operator-facing administration UI.</li>
        <li>The Dashboard is for host and runtime visibility. Torrent submission and lifecycle operations now belong on the dedicated Torrents page.</li>
        <li>TVMaze remains a lightweight client of TorrentCore rather than owning TorrentCore runtime behavior.</li>
    </ul>
</section>

<section>
    <h2>Next Work</h2>
    <ul>
        <li>Add a proper torrent detail page with deeper runtime, file, and scheduling diagnostics.</li>
        <li>Add Intel Mac deployment scripts for publish, deploy, start, stop, and restart.</li>
        <li>Continue expanding operator-managed runtime and saturation controls beyond the current queue and engine-throttle settings.</li>
    </ul>
</section>

@code {
    private EngineHostStatusDto? _hostStatus;
    private string? _error;
    private bool _isLoading = true;
    private readonly SemaphoreSlim _loadGate = new(1, 1);
    private CancellationTokenSource? _refreshLoopCts;
    private Task? _refreshLoopTask;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _refreshLoopCts = new CancellationTokenSource();
        _refreshLoopTask = RunRefreshLoopAsync(_refreshLoopCts.Token);
    }

    private async Task LoadAsync()
    {
        await _loadGate.WaitAsync();

        try
        {
            _error = null;
            _hostStatus = await TorrentCoreClient.GetHostStatusAsync();
        }
        catch (Exception exception)
        {
            _error = $"Unable to reach TorrentCore service: {exception.Message}";
        }
        finally
        {
            _isLoading = false;
            _loadGate.Release();
        }
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
    }

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));

        while (await timer.WaitForNextTickAsync(cancellationToken))
        {
            await InvokeAsync(async () =>
            {
                await LoadAsync();
                StateHasChanged();
            });
        }
    }

    private static string FormatRate(long bytesPerSecond) =>
        $"{bytesPerSecond / 1_000_000.0:0.00} MB/s";

    private static string FormatRateLimit(int bytesPerSecond) =>
        bytesPerSecond <= 0 ? "Unlimited" : FormatRate(bytesPerSecond);

    public async ValueTask DisposeAsync()
    {
        if (_refreshLoopCts is not null)
        {
            await _refreshLoopCts.CancelAsync();
            _refreshLoopCts.Dispose();
        }

        if (_refreshLoopTask is not null)
        {
            try
            {
                await _refreshLoopTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _loadGate.Dispose();
    }
}
