@page "/settings"
@inject TorrentCoreClient TorrentCoreClient
@using System.Globalization
@using TorrentCore.Contracts.Categories
@using TorrentCore.Contracts.Host

<PageTitle>Settings</PageTitle>

<h1>Runtime Settings</h1>

<p>Operator settings for seeding policy, cleanup, queue concurrency, engine throttling, shared callback configuration, and category routing. Queue and policy settings apply live. Engine throttle changes are saved and apply after the service restarts.</p>

@if (_isLoading)
{
    <p>Loading runtime settings...</p>
}
else
{
    <section class="mb-4">
        <h2 class="h5">Current Engine Runtime</h2>
        <div class="row g-3">
            <div class="col-12 col-sm-6 col-xl-3">
                <label class="form-label" for="engineRuntime">Engine Runtime</label>
                <input id="engineRuntime" class="form-control" value="@_engineRuntime" readonly />
            </div>
            <div class="col-12 col-sm-6 col-xl-3">
                <label class="form-label" for="partialFiles">Partial Files</label>
                <input id="partialFiles" class="form-control" value="@_partialFilesSummary" readonly />
            </div>
            <div class="col-12 col-sm-6 col-xl-3">
                <label class="form-label" for="persistedOverrides">Persisted Overrides</label>
                <input id="persistedOverrides" class="form-control" value="@_persistedOverridesSummary" readonly />
            </div>
            <div class="col-12 col-sm-6 col-xl-3">
                <label class="form-label" for="updatedAt">Last Updated</label>
                <input id="updatedAt" class="form-control" value="@_updatedAtSummary" readonly />
            </div>
        </div>
    </section>

    <section class="mb-4">
        <h2 class="h5">Currently Applied Engine Throttles</h2>
        <p class="text-muted mb-2">These are the values the running engine is using right now.</p>
        <div class="row g-3">
            <div class="col-12 col-sm-6 col-xl-3">
                <label class="form-label" for="appliedMaxConnections">Current Max Connections</label>
                <input id="appliedMaxConnections" class="form-control" value="@_appliedMaxConnections.ToString(CultureInfo.InvariantCulture)" readonly />
            </div>
            <div class="col-12 col-sm-6 col-xl-3">
                <label class="form-label" for="appliedHalfOpenConnections">Current Half-Open Connections</label>
                <input id="appliedHalfOpenConnections" class="form-control" value="@_appliedHalfOpenConnections.ToString(CultureInfo.InvariantCulture)" readonly />
            </div>
            <div class="col-12 col-sm-6 col-xl-3">
                <label class="form-label" for="appliedDownloadRate">Current Max Download Rate</label>
                <input id="appliedDownloadRate" class="form-control" value="@FormatRateLimit(_appliedDownloadRateBytesPerSecond)" readonly />
            </div>
            <div class="col-12 col-sm-6 col-xl-3">
                <label class="form-label" for="appliedUploadRate">Current Max Upload Rate</label>
                <input id="appliedUploadRate" class="form-control" value="@FormatRateLimit(_appliedUploadRateBytesPerSecond)" readonly />
            </div>
        </div>
    </section>

    <EditForm Model="this" OnValidSubmit="SaveAsync">
        <section class="mb-4">
            <h2 class="h5">Live Policy Settings</h2>
            <p class="text-muted mb-2">These settings take effect without restarting the service.</p>
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="form-label" for="seedingStopMode">Seeding Stop Mode</label>
                    <select id="seedingStopMode" class="form-select" @bind="_seedingStopMode">
                        <option value="Unlimited">Unlimited</option>
                        <option value="StopImmediately">StopImmediately</option>
                        <option value="StopAfterRatio">StopAfterRatio</option>
                        <option value="StopAfterTime">StopAfterTime</option>
                        <option value="StopAfterRatioOrTime">StopAfterRatioOrTime</option>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label" for="seedingStopRatio">Seeding Stop Ratio</label>
                    <input id="seedingStopRatio" class="form-control" type="number" min="0.01" step="0.01" @bind="_seedingStopRatio" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label" for="seedingStopMinutes">Seeding Stop Minutes</label>
                    <input id="seedingStopMinutes" class="form-control" type="number" min="1" step="1" @bind="_seedingStopMinutes" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label" for="cleanupMode">Completed Torrent Cleanup Mode</label>
                    <select id="cleanupMode" class="form-select" @bind="_completedTorrentCleanupMode">
                        <option value="Never">Never</option>
                        <option value="AfterCompletedMinutes">AfterCompletedMinutes</option>
                    </select>
                    <div class="form-text">Automatic cleanup only removes TorrentCore tracking. It never deletes downloaded data.</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label" for="cleanupMinutes">Completed Torrent Cleanup Minutes</label>
                    <input id="cleanupMinutes" class="form-control" type="number" min="0" step="1" @bind="_completedTorrentCleanupMinutes" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label" for="burstLimit">Connection Failure Burst Limit</label>
                    <input id="burstLimit" class="form-control" type="number" min="1" step="1" @bind="_engineConnectionFailureLogBurstLimit" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label" for="windowSeconds">Connection Failure Window Seconds</label>
                    <input id="windowSeconds" class="form-control" type="number" min="1" step="1" @bind="_engineConnectionFailureLogWindowSeconds" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label" for="maxActiveMetadataResolutions">Max Active Metadata Resolutions</label>
                    <input id="maxActiveMetadataResolutions" class="form-control" type="number" min="1" step="1" @bind="_maxActiveMetadataResolutions" />
                    <div class="form-text">New magnets are still accepted immediately. Extra unresolved torrents wait in queue until a metadata slot opens.</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label" for="maxActiveDownloads">Max Active Downloads</label>
                    <input id="maxActiveDownloads" class="form-control" type="number" min="1" step="1" @bind="_maxActiveDownloads" />
                    <div class="form-text">Resolved torrents above this limit stay queued until a download slot opens.</div>
                </div>
            </div>
        </section>

        <section class="mb-4">
            <h2 class="h5">Saved Engine Throttle Settings</h2>
            <p class="text-muted mb-2">These values are saved immediately but only apply after `TorrentCore.Service` restarts.</p>
            <div class="row g-3">
                <div class="col-12 col-sm-6 col-xl-3">
                    <label class="form-label" for="engineMaximumConnections">Saved Max Connections</label>
                    <input id="engineMaximumConnections" class="form-control" type="number" min="1" step="1" @bind="_engineMaximumConnections" />
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <label class="form-label" for="engineMaximumHalfOpenConnections">Saved Max Half-Open Connections</label>
                    <input id="engineMaximumHalfOpenConnections" class="form-control" type="number" min="1" step="1" @bind="_engineMaximumHalfOpenConnections" />
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <label class="form-label" for="engineMaximumDownloadRate">Saved Max Download Rate</label>
                    <input id="engineMaximumDownloadRate" class="form-control" type="number" min="0" step="1" @bind="_engineMaximumDownloadRateBytesPerSecond" />
                    <div class="form-text">Use `0` for unlimited.</div>
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <label class="form-label" for="engineMaximumUploadRate">Saved Max Upload Rate</label>
                    <input id="engineMaximumUploadRate" class="form-control" type="number" min="0" step="1" @bind="_engineMaximumUploadRateBytesPerSecond" />
                    <div class="form-text">Use `0` for unlimited.</div>
                </div>
            </div>
        </section>

        <section class="mb-4">
            <h2 class="h5">Shared Callback Settings</h2>
            <p class="text-muted mb-2">These settings describe the existing shared TVMaze callback entrypoint. They are persisted now so the callback slice can be enabled without going back to file edits.</p>
            <div class="row g-3">
                <div class="col-12">
                    <div class="form-check">
                        <input id="completionCallbackEnabled" class="form-check-input" type="checkbox" @bind="_completionCallbackEnabled" />
                        <label class="form-check-label" for="completionCallbackEnabled">Enable completion callback invocation</label>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <label class="form-label" for="completionCallbackCommandPath">Command Path</label>
                    <input id="completionCallbackCommandPath" class="form-control tc-break" @bind="_completionCallbackCommandPath" />
                </div>
                <div class="col-12 col-lg-6">
                    <label class="form-label" for="completionCallbackArguments">Arguments</label>
                    <input id="completionCallbackArguments" class="form-control tc-break" @bind="_completionCallbackArguments" />
                </div>
                <div class="col-12 col-lg-6">
                    <label class="form-label" for="completionCallbackWorkingDirectory">Working Directory</label>
                    <input id="completionCallbackWorkingDirectory" class="form-control tc-break" @bind="_completionCallbackWorkingDirectory" />
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <label class="form-label" for="completionCallbackTimeoutSeconds">Timeout Seconds</label>
                    <input id="completionCallbackTimeoutSeconds" class="form-control" type="number" min="1" step="1" @bind="_completionCallbackTimeoutSeconds" />
                </div>
                <div class="col-12 col-lg-6">
                    <label class="form-label" for="completionCallbackApiBaseUrlOverride">API Base URL Override</label>
                    <input id="completionCallbackApiBaseUrlOverride" class="form-control tc-break" @bind="_completionCallbackApiBaseUrlOverride" />
                </div>
                <div class="col-12 col-lg-6">
                    <label class="form-label" for="completionCallbackApiKeyOverride">API Key Override</label>
                    <input id="completionCallbackApiKeyOverride" class="form-control tc-break" @bind="_completionCallbackApiKeyOverride" />
                </div>
            </div>
        </section>

        <section class="mb-4">
            <h2 class="h5">Categories</h2>
            <p class="text-muted mb-2">These definitions route future torrent adds. Editing a category does not move existing torrents that were already added.</p>
            <div class="row g-3">
                @foreach (var category in _categories.OrderBy(category => category.SortOrder).ThenBy(category => category.Key, StringComparer.OrdinalIgnoreCase))
                {
                    <div class="col-12" @key="category.Key">
                        <div class="card">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h3 class="h6 mb-0">@category.Key</h3>
                                    <div class="tc-toolbar">
                                        <div class="form-check">
                                            <input id="@($"category-enabled-{category.Key}")" class="form-check-input" type="checkbox" @bind="category.Enabled" />
                                            <label class="form-check-label" for="@($"category-enabled-{category.Key}")">Enabled</label>
                                        </div>
                                        <div class="form-check">
                                            <input id="@($"category-callback-{category.Key}")" class="form-check-input" type="checkbox" @bind="category.InvokeCompletionCallback" />
                                            <label class="form-check-label" for="@($"category-callback-{category.Key}")">Invoke Callback</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="row g-3">
                                    <div class="col-12 col-lg-3">
                                        <label class="form-label" for="@($"category-display-{category.Key}")">Display Name</label>
                                        <input id="@($"category-display-{category.Key}")" class="form-control" @bind="category.DisplayName" />
                                    </div>
                                    <div class="col-12 col-lg-3">
                                        <label class="form-label" for="@($"category-label-{category.Key}")">Callback Label</label>
                                        <input id="@($"category-label-{category.Key}")" class="form-control" @bind="category.CallbackLabel" />
                                    </div>
                                    <div class="col-12 col-lg-4">
                                        <label class="form-label" for="@($"category-root-{category.Key}")">Download Root</label>
                                        <input id="@($"category-root-{category.Key}")" class="form-control tc-break" @bind="category.DownloadRootPath" />
                                    </div>
                                    <div class="col-12 col-lg-2">
                                        <label class="form-label" for="@($"category-sort-{category.Key}")">Sort Order</label>
                                        <input id="@($"category-sort-{category.Key}")" class="form-control" type="number" min="0" step="1" @bind="category.SortOrder" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
        <div class="mt-3 tc-toolbar">
            <button class="btn btn-primary" type="submit" disabled="@_isSaving">Save Settings</button>
            <button class="btn btn-secondary" type="button" @onclick="LoadAsync" disabled="@_isSaving">Reload</button>
        </div>
    </EditForm>

    @if (_engineSettingsRequireRestart)
    {
        <p class="mt-3 text-warning">Saved engine throttle settings are pending. Restart `TorrentCore.Service` to apply them.</p>
    }

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <p class="mt-3 text-success">@_message</p>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="mt-3 text-danger">@_error</p>
    }
}

@code {
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _message;
    private string? _error;
    private string _engineRuntime = string.Empty;
    private string _partialFilesSummary = string.Empty;
    private string _persistedOverridesSummary = string.Empty;
    private string _updatedAtSummary = string.Empty;
    private string _seedingStopMode = "Unlimited";
    private double _seedingStopRatio = 1.0;
    private int _seedingStopMinutes = 60;
    private string _completedTorrentCleanupMode = "Never";
    private int _completedTorrentCleanupMinutes = 60;
    private int _engineConnectionFailureLogBurstLimit = 5;
    private int _engineConnectionFailureLogWindowSeconds = 60;
    private int _engineMaximumConnections = 150;
    private int _engineMaximumHalfOpenConnections = 8;
    private int _engineMaximumDownloadRateBytesPerSecond;
    private int _engineMaximumUploadRateBytesPerSecond;
    private int _maxActiveMetadataResolutions = 4;
    private int _maxActiveDownloads = 4;
    private bool _completionCallbackEnabled;
    private string _completionCallbackCommandPath = string.Empty;
    private string _completionCallbackArguments = string.Empty;
    private string _completionCallbackWorkingDirectory = string.Empty;
    private int _completionCallbackTimeoutSeconds = 30;
    private string _completionCallbackApiBaseUrlOverride = string.Empty;
    private string _completionCallbackApiKeyOverride = string.Empty;
    private int _appliedMaxConnections = 150;
    private int _appliedHalfOpenConnections = 8;
    private int _appliedDownloadRateBytesPerSecond;
    private int _appliedUploadRateBytesPerSecond;
    private bool _engineSettingsRequireRestart;
    private List<EditableCategoryModel> _categories = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _message = null;
        _error = null;

        try
        {
            var settingsTask = TorrentCoreClient.GetRuntimeSettingsAsync();
            var categoriesTask = TorrentCoreClient.GetCategoriesAsync();
            await Task.WhenAll(settingsTask, categoriesTask);

            var settings = settingsTask.Result;
            if (settings is null)
            {
                _error = "Runtime settings endpoint returned no payload.";
                return;
            }

            Apply(settings);
            ApplyCategories(categoriesTask.Result);
        }
        catch (Exception exception)
        {
            _error = $"Unable to load runtime settings: {exception.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _message = null;
        _error = null;

        try
        {
            var settings = await TorrentCoreClient.UpdateRuntimeSettingsAsync(new UpdateRuntimeSettingsRequest
            {
                SeedingStopMode = _seedingStopMode,
                SeedingStopRatio = _seedingStopRatio,
                SeedingStopMinutes = _seedingStopMinutes,
                CompletedTorrentCleanupMode = _completedTorrentCleanupMode,
                CompletedTorrentCleanupMinutes = _completedTorrentCleanupMinutes,
                EngineConnectionFailureLogBurstLimit = _engineConnectionFailureLogBurstLimit,
                EngineConnectionFailureLogWindowSeconds = _engineConnectionFailureLogWindowSeconds,
                EngineMaximumConnections = _engineMaximumConnections,
                EngineMaximumHalfOpenConnections = _engineMaximumHalfOpenConnections,
                EngineMaximumDownloadRateBytesPerSecond = _engineMaximumDownloadRateBytesPerSecond,
                EngineMaximumUploadRateBytesPerSecond = _engineMaximumUploadRateBytesPerSecond,
                MaxActiveMetadataResolutions = _maxActiveMetadataResolutions,
                MaxActiveDownloads = _maxActiveDownloads,
                CompletionCallbackEnabled = _completionCallbackEnabled,
                CompletionCallbackCommandPath = _completionCallbackCommandPath,
                CompletionCallbackArguments = _completionCallbackArguments,
                CompletionCallbackWorkingDirectory = _completionCallbackWorkingDirectory,
                CompletionCallbackTimeoutSeconds = _completionCallbackTimeoutSeconds,
                CompletionCallbackApiBaseUrlOverride = _completionCallbackApiBaseUrlOverride,
                CompletionCallbackApiKeyOverride = _completionCallbackApiKeyOverride,
            });

            var updatedCategories = new List<TorrentCategoryDto>(_categories.Count);
            foreach (var category in _categories.OrderBy(category => category.SortOrder).ThenBy(category => category.Key, StringComparer.OrdinalIgnoreCase))
            {
                updatedCategories.Add(await TorrentCoreClient.UpdateCategoryAsync(category.Key, new UpdateTorrentCategoryRequest
                {
                    DisplayName = category.DisplayName,
                    CallbackLabel = category.CallbackLabel,
                    DownloadRootPath = category.DownloadRootPath,
                    Enabled = category.Enabled,
                    InvokeCompletionCallback = category.InvokeCompletionCallback,
                    SortOrder = category.SortOrder,
                }));
            }

            Apply(settings);
            ApplyCategories(updatedCategories);
            _message = settings.EngineSettingsRequireRestart
                ? "Runtime settings and categories saved. Restart TorrentCore.Service to apply the engine throttle changes."
                : "Runtime settings and categories saved.";
        }
        catch (Exception exception)
        {
            _error = $"Unable to save runtime settings: {exception.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Apply(RuntimeSettingsDto settings)
    {
        _engineRuntime = settings.EngineRuntime;
        _partialFilesSummary = settings.PartialFilesEnabled
            ? $"Enabled ({settings.PartialFileSuffix})"
            : "Disabled";
        _persistedOverridesSummary = settings.UsesPersistedOverrides ? "Yes" : "No";
        _updatedAtSummary = settings.UpdatedAtUtc?.ToLocalTime().ToString("g", CultureInfo.CurrentCulture) ?? "Not yet changed";
        _seedingStopMode = settings.SeedingStopMode;
        _seedingStopRatio = settings.SeedingStopRatio;
        _seedingStopMinutes = settings.SeedingStopMinutes;
        _completedTorrentCleanupMode = settings.CompletedTorrentCleanupMode;
        _completedTorrentCleanupMinutes = settings.CompletedTorrentCleanupMinutes;
        _engineConnectionFailureLogBurstLimit = settings.EngineConnectionFailureLogBurstLimit;
        _engineConnectionFailureLogWindowSeconds = settings.EngineConnectionFailureLogWindowSeconds;
        _engineMaximumConnections = settings.EngineMaximumConnections;
        _engineMaximumHalfOpenConnections = settings.EngineMaximumHalfOpenConnections;
        _engineMaximumDownloadRateBytesPerSecond = settings.EngineMaximumDownloadRateBytesPerSecond;
        _engineMaximumUploadRateBytesPerSecond = settings.EngineMaximumUploadRateBytesPerSecond;
        _maxActiveMetadataResolutions = settings.MaxActiveMetadataResolutions;
        _maxActiveDownloads = settings.MaxActiveDownloads;
        _completionCallbackEnabled = settings.CompletionCallbackEnabled;
        _completionCallbackCommandPath = settings.CompletionCallbackCommandPath ?? string.Empty;
        _completionCallbackArguments = settings.CompletionCallbackArguments ?? string.Empty;
        _completionCallbackWorkingDirectory = settings.CompletionCallbackWorkingDirectory ?? string.Empty;
        _completionCallbackTimeoutSeconds = settings.CompletionCallbackTimeoutSeconds;
        _completionCallbackApiBaseUrlOverride = settings.CompletionCallbackApiBaseUrlOverride ?? string.Empty;
        _completionCallbackApiKeyOverride = settings.CompletionCallbackApiKeyOverride ?? string.Empty;
        _appliedMaxConnections = settings.AppliedEngineMaximumConnections;
        _appliedHalfOpenConnections = settings.AppliedEngineMaximumHalfOpenConnections;
        _appliedDownloadRateBytesPerSecond = settings.AppliedEngineMaximumDownloadRateBytesPerSecond;
        _appliedUploadRateBytesPerSecond = settings.AppliedEngineMaximumUploadRateBytesPerSecond;
        _engineSettingsRequireRestart = settings.EngineSettingsRequireRestart;
    }

    private void ApplyCategories(IReadOnlyList<TorrentCategoryDto> categories)
    {
        _categories = categories
            .OrderBy(category => category.SortOrder)
            .ThenBy(category => category.Key, StringComparer.OrdinalIgnoreCase)
            .Select(category => new EditableCategoryModel
            {
                Key = category.Key,
                DisplayName = category.DisplayName,
                CallbackLabel = category.CallbackLabel,
                DownloadRootPath = category.DownloadRootPath,
                Enabled = category.Enabled,
                InvokeCompletionCallback = category.InvokeCompletionCallback,
                SortOrder = category.SortOrder,
            })
            .ToList();
    }

    private static string FormatRateLimit(int bytesPerSecond) =>
        bytesPerSecond <= 0 ? "Unlimited" : $"{bytesPerSecond / 1_000_000.0:0.00} MB/s";

    private sealed class EditableCategoryModel
    {
        public required string Key { get; init; }
        public required string DisplayName { get; set; }
        public required string CallbackLabel { get; set; }
        public required string DownloadRootPath { get; set; }
        public required bool Enabled { get; set; }
        public required bool InvokeCompletionCallback { get; set; }
        public required int SortOrder { get; set; }
    }
}
