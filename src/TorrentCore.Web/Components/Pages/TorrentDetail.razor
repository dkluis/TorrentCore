@page "/torrents/{TorrentId:guid}"
@implements IAsyncDisposable
@inject NavigationManager NavigationManager
@inject TorrentCoreClient TorrentCoreClient
@using System.Globalization
@using System.Text.Json
@using TorrentCore.Contracts.Diagnostics
@using TorrentCore.Contracts.Torrents

<PageTitle>Torrent Detail</PageTitle>

<h1>Torrent Detail</h1>

<p><a href="/torrents">Back to Torrents</a></p>

@if (_isLoading)
{
    <p>Loading torrent detail...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <p>@_error</p>
}
else if (_torrent is not null)
{
    <section class="mb-4">
        <div class="tc-section-header mb-3">
            <div>
                <h2 class="mb-1 tc-break">@_torrent.Name</h2>
                <p class="text-muted mb-0 tc-break">Torrent id: @_torrent.TorrentId</p>
            </div>
            <div class="tc-toolbar">
                <button class="btn btn-secondary" type="button" @onclick="RefreshAsync" disabled="@_isBusy">Refresh</button>
                @if (_torrent.CanPause)
                {
                    <button class="btn btn-outline-secondary" type="button" @onclick="PauseAsync" disabled="@_isBusy">Pause</button>
                }
                @if (_torrent.CanResume)
                {
                    <button class="btn btn-outline-secondary" type="button" @onclick="ResumeAsync" disabled="@_isBusy">Resume</button>
                }
                @if (_torrent.CanRetryCompletionCallback)
                {
                    <button class="btn btn-outline-secondary" type="button" @onclick="RetryCompletionCallbackAsync" disabled="@_isBusy">Retry Callback</button>
                }
                @if (_torrent.CanRemove)
                {
                    <button class="btn btn-outline-danger" type="button" @onclick="RemoveAsync" disabled="@_isBusy">Remove</button>
                    @if (CanDeleteData(_torrent))
                    {
                        <button class="btn btn-danger" type="button" @onclick="DeleteDataAsync" disabled="@_isBusy">Delete Data</button>
                    }
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <p class="text-success">@_message</p>
        }
    </section>

    <section class="mb-4">
        <div class="row g-3">
            <div class="col-xl-3 col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 card-title">Runtime</h3>
                        <p class="mb-1"><strong>Status:</strong> @_torrent.State</p>
                        <p class="mb-1"><strong>Wait:</strong> @FormatWaitReason(_torrent.WaitReason, _torrent.QueuePosition)</p>
                        <p class="mb-1"><strong>Progress:</strong> @_torrent.ProgressPercent.ToString("0.0")%</p>
                        <p class="mb-1"><strong>Download Rate:</strong> @FormatRate(_torrent.DownloadRateBytesPerSecond)</p>
                        <p class="mb-1"><strong>Upload Rate:</strong> @FormatRate(_torrent.UploadRateBytesPerSecond)</p>
                        <p class="mb-1"><strong>Peers:</strong> @_torrent.ConnectedPeerCount</p>
                        <p class="mb-0"><strong>Trackers:</strong> @_torrent.TrackerCount</p>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 card-title">Transfer</h3>
                        <p class="mb-1"><strong>Downloaded:</strong> @FormatBytes(_torrent.DownloadedBytes)</p>
                        <p class="mb-1"><strong>Total Size:</strong> @FormatOptionalBytes(_torrent.TotalBytes)</p>
                        <p class="mb-1"><strong>Magnet Resolved:</strong> @(_torrent.TotalBytes is not null)</p>
                        <p class="mb-0"><strong>Error:</strong> @(string.IsNullOrWhiteSpace(_torrent.ErrorMessage) ? "None" : _torrent.ErrorMessage)</p>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 card-title">Identity</h3>
                        <p class="mb-1"><strong>Info Hash:</strong> <span class="tc-break">@(_torrent.InfoHash ?? "Pending metadata")</span></p>
                        <p class="mb-1"><strong>Added:</strong> @_torrent.AddedAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)</p>
                        <p class="mb-1"><strong>Completed:</strong> @FormatLocalTime(_torrent.CompletedAtUtc)</p>
                        <p class="mb-1"><strong>Last Activity:</strong> @FormatLocalTime(_torrent.LastActivityAtUtc)</p>
                        <p class="mb-0"><strong>Save Path:</strong> <span class="tc-break">@_torrent.SavePath</span></p>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 card-title">Magnet</h3>
                        <p class="mb-0 tc-code-wrap"><code>@_torrent.MagnetUri</code></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-4">
        <div class="row g-3">
            <div class="col-xl-6 col-lg-8">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="tc-section-header mb-3">
                            <h3 class="h6 card-title mb-0">Completion Callback</h3>
                            @if (_torrent.CanRetryCompletionCallback)
                            {
                                <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="RetryCompletionCallbackAsync" disabled="@_isBusy">Retry</button>
                            }
                        </div>
                        <p class="mb-1"><strong>Status:</strong> @FormatCompletionCallbackState(_torrent.CompletionCallbackState, _torrent.CompletedAtUtc)</p>
                        <p class="mb-1"><strong>Pending Since:</strong> @FormatLocalTime(_torrent.CompletionCallbackPendingSinceUtc)</p>
                        <p class="mb-1"><strong>Invoked:</strong> @FormatLocalTime(_torrent.CompletionCallbackInvokedAtUtc)</p>
                        <p class="mb-1"><strong>Final Payload:</strong> <span class="tc-break">@(_torrent.CompletionCallbackFinalPayloadPath ?? "Not available")</span></p>
                        <p class="mb-1"><strong>Pending Reason:</strong> @(string.IsNullOrWhiteSpace(_torrent.CompletionCallbackPendingReason) ? "None" : _torrent.CompletionCallbackPendingReason)</p>
                        <p class="mb-1"><strong>Last Error:</strong> @(string.IsNullOrWhiteSpace(_torrent.CompletionCallbackLastError) ? "None" : _torrent.CompletionCallbackLastError)</p>
                        <hr />
                        <p class="mb-1"><strong>Last Event:</strong> @FormatCallbackEvent(_latestCallbackLog)</p>
                        <p class="mb-1"><strong>Last Event Time:</strong> @FormatCallbackEventTime(_latestCallbackLog)</p>
                        <p class="mb-1"><strong>Last Message:</strong> @(_latestCallbackLog?.Message ?? "Not yet")</p>
                        <p class="mb-1"><strong>Process Id:</strong> @FormatNullableInt(_latestCallbackLog?.ProcessId)</p>
                        <p class="mb-1"><strong>Exit Code:</strong> @FormatNullableInt(_latestCallbackLog?.ExitCode)</p>
                        <p class="mb-1"><strong>Command:</strong> <span class="tc-break">@(_latestCallbackLog?.CommandPath ?? "Not yet")</span></p>
                        <p class="mb-1"><strong>Working Directory:</strong> <span class="tc-break">@(_latestCallbackLog?.WorkingDirectory ?? "Not yet")</span></p>
                        <p class="mb-1"><strong>Process Timeout:</strong> @FormatTimeoutSeconds(_latestCallbackLog?.ProcessTimeoutSeconds)</p>
                        <p class="mb-0"><strong>Finalization Wait:</strong> @FormatTimeoutSeconds(_latestCallbackLog?.FinalizationTimeoutSeconds)</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="tc-section-header mb-3">
            <h2 class="mb-0">Recent Torrent Logs</h2>
            <span class="text-muted">Local time</span>
        </div>

        @if (_logs.Count == 0)
        {
            <p>No recent log entries for this torrent.</p>
        }
        else
        {
            <div class="tc-table-wrap d-none d-md-block">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>When</th>
                        <th>Level</th>
                        <th>Category</th>
                        <th>Event</th>
                        <th>Message</th>
                        <th>Details</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var log in _logs)
                    {
                        <tr>
                            <td>@log.OccurredAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)</td>
                            <td>@log.Level</td>
                            <td>@log.Category</td>
                            <td><code>@log.EventType</code></td>
                            <td class="tc-break">@log.Message</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(log.DetailsJson))
                                {
                                    <details>
                                        <summary>Show</summary>
                                        <pre class="mb-0 tc-code-wrap"><code>@log.DetailsJson</code></pre>
                                    </details>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="d-md-none tc-card-list">
                @foreach (var log in _logs)
                {
                    <article class="tc-mobile-card">
                        <dl class="tc-mobile-definition-list mb-2">
                            <dt>When</dt>
                            <dd>@log.OccurredAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)</dd>
                            <dt>Level</dt>
                            <dd>@log.Level</dd>
                            <dt>Category</dt>
                            <dd>@log.Category</dd>
                            <dt>Event</dt>
                            <dd class="tc-code-wrap"><code>@log.EventType</code></dd>
                            <dt>Message</dt>
                            <dd class="tc-break">@log.Message</dd>
                        </dl>

                        @if (!string.IsNullOrWhiteSpace(log.DetailsJson))
                        {
                            <details>
                                <summary>Details</summary>
                                <pre class="mb-0 tc-code-wrap"><code>@log.DetailsJson</code></pre>
                            </details>
                        }
                    </article>
                }
            </div>
        }
    </section>
}

@code {
    [Parameter]
    public Guid TorrentId { get; set; }

    private TorrentDetailDto? _torrent;
    private IReadOnlyList<ActivityLogEntryDto> _logs = Array.Empty<ActivityLogEntryDto>();
    private CallbackLogSummary? _latestCallbackLog;
    private string? _error;
    private string? _message;
    private bool _isLoading = true;
    private bool _isBusy;
    private readonly SemaphoreSlim _loadGate = new(1, 1);
    private CancellationTokenSource? _refreshLoopCts;
    private Task? _refreshLoopTask;
    private bool _isDisposed;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _refreshLoopCts = new CancellationTokenSource();
        _refreshLoopTask = RunRefreshLoopAsync(_refreshLoopCts.Token);
    }

    private async Task LoadAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        await _loadGate.WaitAsync();

        try
        {
            if (_isDisposed)
            {
                return;
            }

            _error = null;
            _torrent = await TorrentCoreClient.GetTorrentAsync(TorrentId);

            if (_torrent is null)
            {
                _error = $"Torrent '{TorrentId}' was not found.";
                _logs = Array.Empty<ActivityLogEntryDto>();
                _latestCallbackLog = null;
                return;
            }

            _logs = await TorrentCoreClient.GetRecentLogsAsync(
                take: 20,
                torrentId: TorrentId);
            _latestCallbackLog = GetLatestCallbackLog(_logs);
        }
        catch (TorrentCoreClientException exception)
        {
            _error = exception.ServiceError?.Message ?? exception.Message;
        }
        catch (Exception exception)
        {
            _error = $"Unable to load torrent detail: {exception.Message}";
        }
        finally
        {
            _isLoading = false;
            _loadGate.Release();
        }
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
    }

    private async Task PauseAsync()
    {
        if (_torrent is null)
        {
            return;
        }

        await RunActionAsync(async () =>
        {
            var result = await TorrentCoreClient.PauseAsync(_torrent.TorrentId);
            _message = $"Paused at {result.ProcessedAtUtc.ToLocalTime():g}.";
        });
    }

    private async Task ResumeAsync()
    {
        if (_torrent is null)
        {
            return;
        }

        await RunActionAsync(async () =>
        {
            var result = await TorrentCoreClient.ResumeAsync(_torrent.TorrentId);
            _message = $"Resumed at {result.ProcessedAtUtc.ToLocalTime():g}.";
        });
    }

    private async Task RetryCompletionCallbackAsync()
    {
        if (_torrent is null)
        {
            return;
        }

        await RunActionAsync(async () =>
        {
            var result = await TorrentCoreClient.RetryCompletionCallbackAsync(_torrent.TorrentId);
            _message = $"Queued completion callback retry at {result.ProcessedAtUtc.ToLocalTime():g}.";
        });
    }

    private async Task RemoveAsync()
    {
        if (_torrent is null)
        {
            return;
        }

        await RunActionAsync(
            async () =>
            {
                await TorrentCoreClient.RemoveAsync(_torrent.TorrentId, new RemoveTorrentRequest
                {
                    DeleteData = false,
                });

                NavigationManager.NavigateTo("/torrents");
            },
            reloadAfter: false);
    }

    private async Task DeleteDataAsync()
    {
        if (_torrent is null)
        {
            return;
        }

        await RunActionAsync(
            async () =>
            {
                await TorrentCoreClient.RemoveAsync(_torrent.TorrentId, new RemoveTorrentRequest
                {
                    DeleteData = true,
                });

                NavigationManager.NavigateTo("/torrents");
            },
            reloadAfter: false);
    }

    private async Task RunActionAsync(Func<Task> action, bool reloadAfter = true)
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;
        _message = null;
        _error = null;

        try
        {
            await action();
            if (reloadAfter)
            {
                await LoadAsync();
            }
        }
        catch (TorrentCoreClientException exception)
        {
            _error = exception.ServiceError?.Message ?? exception.Message;
        }
        catch (Exception exception)
        {
            _error = $"Torrent action failed: {exception.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));

        while (await timer.WaitForNextTickAsync(cancellationToken))
        {
            if (_isBusy)
            {
                continue;
            }

            await InvokeAsync(async () =>
            {
                if (_isDisposed)
                {
                    return;
                }

                await LoadAsync();
                StateHasChanged();
            });
        }
    }

    private static string FormatRate(long bytesPerSecond) =>
        $"{bytesPerSecond / 1_000_000.0:0.00} MB/s";

    private static string FormatBytes(long bytes) =>
        $"{bytes / 1_000_000.0:0.00} MB";

    private static string FormatOptionalBytes(long? bytes) =>
        bytes is null ? "Unknown" : FormatBytes(bytes.Value);

    private static string FormatLocalTime(DateTimeOffset? value) =>
        value?.ToLocalTime().ToString("g", CultureInfo.CurrentCulture) ?? "Not yet";

    private static string FormatCompletionCallbackState(string? state, DateTimeOffset? completedAtUtc) =>
        !string.IsNullOrWhiteSpace(state)
            ? state
            : completedAtUtc is null
                ? "Waiting for completion"
                : "Not requested";

    private static string FormatCallbackEvent(CallbackLogSummary? callbackLog) =>
        callbackLog is null
            ? "Not yet"
            : FormatCallbackEventName(callbackLog.EventType);

    private static string FormatCallbackEventTime(CallbackLogSummary? callbackLog) =>
        callbackLog is null
            ? "Not yet"
            : callbackLog.OccurredAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentCulture);

    private static string FormatNullableInt(int? value) =>
        value?.ToString(CultureInfo.CurrentCulture) ?? "Not available";

    private static string FormatTimeoutSeconds(int? value) =>
        value is null ? "Not available" : $"{value.Value.ToString(CultureInfo.CurrentCulture)} seconds";

    private static string FormatCallbackEventName(string eventType)
    {
        const string prefix = "torrent.callback.";
        var normalized = eventType.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
            ? eventType[prefix.Length..]
            : eventType;
        var parts = normalized.Split('_', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 0
            ? eventType
            : string.Join(' ', parts.Select(static part => char.ToUpperInvariant(part[0]) + part[1..]));
    }

    private static CallbackLogSummary? GetLatestCallbackLog(IReadOnlyList<ActivityLogEntryDto> logs)
    {
        var callbackLog = logs
            .Where(log => log.EventType.StartsWith("torrent.callback.", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(log => log.OccurredAtUtc)
            .FirstOrDefault();

        if (callbackLog is null)
        {
            return null;
        }

        string? commandPath = null;
        string? workingDirectory = null;
        int? processId = null;
        int? exitCode = null;
        int? processTimeoutSeconds = null;
        int? finalizationTimeoutSeconds = null;

        if (!string.IsNullOrWhiteSpace(callbackLog.DetailsJson))
        {
            try
            {
                using var document = JsonDocument.Parse(callbackLog.DetailsJson);
                var root = document.RootElement;
                commandPath = GetOptionalString(root, "CommandPath");
                workingDirectory = GetOptionalString(root, "WorkingDirectory");
                processId = GetOptionalInt32(root, "ProcessId");
                exitCode = GetOptionalInt32(root, "ExitCode");
                processTimeoutSeconds = GetOptionalInt32(root, "CompletionCallbackTimeoutSeconds");
                finalizationTimeoutSeconds = GetOptionalInt32(root, "CompletionCallbackFinalizationTimeoutSeconds");
            }
            catch (JsonException)
            {
            }
        }

        return new CallbackLogSummary(
            callbackLog.EventType,
            callbackLog.OccurredAtUtc,
            callbackLog.Message,
            commandPath,
            workingDirectory,
            processId,
            exitCode,
            processTimeoutSeconds,
            finalizationTimeoutSeconds);
    }

    private static string? GetOptionalString(JsonElement root, string propertyName) =>
        root.TryGetProperty(propertyName, out var value) && value.ValueKind == JsonValueKind.String
            ? value.GetString()
            : null;

    private static int? GetOptionalInt32(JsonElement root, string propertyName) =>
        root.TryGetProperty(propertyName, out var value) && value.ValueKind == JsonValueKind.Number && value.TryGetInt32(out var number)
            ? number
            : null;

    private static string FormatWaitReason(TorrentWaitReason? waitReason, int? queuePosition)
    {
        var text = waitReason switch
        {
            TorrentWaitReason.PendingMetadataDispatch => "Pending metadata dispatch",
            TorrentWaitReason.WaitingForMetadataSlot => "Waiting for metadata slot",
            TorrentWaitReason.PendingDownloadDispatch => "Pending download dispatch",
            TorrentWaitReason.WaitingForDownloadSlot => "Waiting for download slot",
            TorrentWaitReason.PausedByOperator => "Paused by operator",
            TorrentWaitReason.BlockedByError => "Blocked by error",
            _ => "Not waiting",
        };

        return queuePosition is null || waitReason is null
            ? text
            : $"{text} (#{queuePosition.Value})";
    }

    private static bool CanDeleteData(TorrentDetailDto torrent) =>
        torrent.State is TorrentState.ResolvingMetadata or TorrentState.Queued or TorrentState.Downloading or TorrentState.Error or TorrentState.Paused;

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;

        if (_refreshLoopCts is not null)
        {
            await _refreshLoopCts.CancelAsync();
            _refreshLoopCts.Dispose();
        }

        if (_refreshLoopTask is not null)
        {
            try
            {
                await _refreshLoopTask;
            }
            catch (OperationCanceledException)
            {
            }
        }
    }

    private sealed record CallbackLogSummary(
        string EventType,
        DateTimeOffset OccurredAtUtc,
        string Message,
        string? CommandPath,
        string? WorkingDirectory,
        int? ProcessId,
        int? ExitCode,
        int? ProcessTimeoutSeconds,
        int? FinalizationTimeoutSeconds);
}
