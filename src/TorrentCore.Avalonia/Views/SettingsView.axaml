<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TorrentCore.Avalonia.ViewModels"
             x:Class="TorrentCore.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="{DynamicResource PagePadding}" Spacing="18">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
        <StackPanel Spacing="4">
          <TextBlock Text="Runtime Settings" Classes="text-page-title" />
          <TextBlock Text="Queue and policy settings apply live. Engine throttle changes are saved and apply after the service restarts."
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
        <Button Grid.Column="1"
                Classes="toolbar-action"
                Content="Reload"
                Command="{Binding RefreshCommand}" />
        <Button Grid.Column="2"
                Classes="toolbar-action accent"
                Content="Save Settings"
                Command="{Binding SaveCommand}" />
      </Grid>

      <TextBlock Text="{Binding Message}"
                 IsVisible="{Binding HasMessage}"
                 Foreground="{DynamicResource TextSecondaryBrush}" />
      <TextBlock Text="{Binding ErrorMessage}"
                 IsVisible="{Binding HasError}"
                 Foreground="{DynamicResource ErrorTextBrush}"
                 TextWrapping="Wrap" />

      <WrapPanel Orientation="Horizontal" ItemWidth="310">
        <Border Classes="panel-card" Margin="0,0,18,18">
          <StackPanel Spacing="10">
            <TextBlock Text="Current Engine Runtime" Classes="text-section-title" />
            <TextBlock Text="{Binding EngineRuntime, StringFormat='Engine Runtime: {0}'}" />
            <TextBlock Text="{Binding PartialFilesSummary, StringFormat='Partial Files: {0}'}" />
            <TextBlock Text="{Binding SupportsLiveUpdates, StringFormat='Supports Live Updates: {0}'}" />
            <TextBlock Text="{Binding PersistedOverridesSummary, StringFormat='Persisted Overrides: {0}'}" />
            <TextBlock Text="{Binding UpdatedAtSummary, StringFormat='Last Updated: {0}'}" />
            <TextBlock Text="{Binding RetrievedAtSummary, StringFormat='Retrieved At: {0}'}"
                       Classes="text-body-small"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>

        <Border Classes="panel-card" Margin="0,0,18,18">
          <StackPanel Spacing="10">
            <TextBlock Text="Applied Engine Throttles" Classes="text-section-title" />
            <TextBlock Text="{Binding AppliedMaxConnections, StringFormat='Current Max Connections: {0}'}" />
            <TextBlock Text="{Binding AppliedHalfOpenConnections, StringFormat='Current Half-Open Connections: {0}'}" />
            <TextBlock Text="{Binding AppliedDownloadRateText, StringFormat='Current Max Download: {0}'}" />
            <TextBlock Text="{Binding AppliedUploadRateText, StringFormat='Current Max Upload: {0}'}" />
          </StackPanel>
        </Border>
      </WrapPanel>

      <StackPanel Spacing="12">
        <TextBlock Text="Live Policy Settings" Classes="text-section-title" />
        <TextBlock Text="These settings apply immediately without restarting the service."
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <WrapPanel Orientation="Horizontal" ItemWidth="360">
          <Border Classes="panel-card" Margin="0,0,18,18">
            <StackPanel Spacing="10">
              <TextBlock Text="Seeding Policy" Classes="text-panel-title" />
              <StackPanel Spacing="4">
                <TextBlock Text="Seeding Stop Mode" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <ComboBox ItemsSource="{Binding SeedingModes}" SelectedItem="{Binding SeedingStopMode}" />
              </StackPanel>
              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <StackPanel Spacing="4">
                  <TextBlock Text="Seeding Stop Ratio" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBox Text="{Binding SeedingStopRatio}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Seeding Stop Minutes" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBox Text="{Binding SeedingStopMinutes}" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="panel-card" Margin="0,0,18,18">
            <StackPanel Spacing="10">
              <TextBlock Text="Cleanup Policy" Classes="text-panel-title" />
              <StackPanel Spacing="4">
                <TextBlock Text="Completed Torrent Cleanup Mode" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <ComboBox ItemsSource="{Binding CleanupModes}" SelectedItem="{Binding CompletedTorrentCleanupMode}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Completed Torrent Cleanup Minutes" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding CompletedTorrentCleanupMinutes}" />
              </StackPanel>
              <TextBlock Text="Automatic cleanup removes TorrentCore tracking only. It never deletes downloaded data."
                         Classes="text-body-small"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
          </Border>

          <Border Classes="panel-card" Margin="0,0,18,18">
            <StackPanel Spacing="10">
              <TextBlock Text="Queue Limits" Classes="text-panel-title" />
              <StackPanel Spacing="4">
                <TextBlock Text="Max Active Metadata Resolutions" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding MaxActiveMetadataResolutions}" />
              </StackPanel>
              <TextBlock Text="New magnets are still accepted immediately. Extra unresolved torrents wait in queue until a metadata slot opens."
                         Classes="text-body-small"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <StackPanel Spacing="4">
                <TextBlock Text="Max Active Downloads" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding MaxActiveDownloads}" />
              </StackPanel>
              <TextBlock Text="Resolved torrents above this limit stay queued until a download slot opens."
                         Classes="text-body-small"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
          </Border>

          <Border Classes="panel-card" Margin="0,0,18,18">
            <StackPanel Spacing="10">
              <TextBlock Text="Log Throttling" Classes="text-panel-title" />
              <StackPanel Spacing="4">
                <TextBlock Text="Connection Failure Burst Limit" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding EngineConnectionFailureLogBurstLimit}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Connection Failure Window Seconds" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding EngineConnectionFailureLogWindowSeconds}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </WrapPanel>
      </StackPanel>

      <StackPanel Spacing="12">
        <TextBlock Text="Saved Engine Throttle Settings" Classes="text-section-title" />
        <TextBlock Text="These values are saved immediately but only apply after TorrentCore.Service restarts."
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <WrapPanel Orientation="Horizontal" ItemWidth="360">
          <Border Classes="panel-card" Margin="0,0,18,18">
            <StackPanel Spacing="10">
              <TextBlock Text="Connection Limits" Classes="text-panel-title" />
              <StackPanel Spacing="4">
                <TextBlock Text="Saved Max Connections" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding EngineMaximumConnections}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Saved Max Half-Open Connections" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding EngineMaximumHalfOpenConnections}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="panel-card" Margin="0,0,18,18">
            <StackPanel Spacing="10">
              <TextBlock Text="Transfer Limits" Classes="text-panel-title" />
              <StackPanel Spacing="4">
                <TextBlock Text="Saved Max Download Rate" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding EngineMaximumDownloadRateBytesPerSecond}" />
                <TextBlock Text="Use 0 for unlimited."
                           Classes="text-body-small"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Saved Max Upload Rate" Classes="text-body-small" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding EngineMaximumUploadRateBytesPerSecond}" />
                <TextBlock Text="Use 0 for unlimited."
                           Classes="text-body-small"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </WrapPanel>
        <TextBlock Text="Saved engine throttle settings are pending. Restart TorrentCore.Service to apply them."
                   IsVisible="{Binding EngineSettingsRequireRestart}"
                   Foreground="{DynamicResource WarningTextBrush}" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
