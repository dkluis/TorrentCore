<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TorrentCore.Avalonia.ViewModels"
             xmlns:diag="using:TorrentCore.Contracts.Diagnostics"
             x:Class="TorrentCore.Avalonia.Views.LogsView"
             x:DataType="vm:LogsViewModel">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="{DynamicResource PagePadding}" Spacing="18">
      <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center" ColumnSpacing="10">
        <StackPanel Spacing="4">
          <TextBlock Text="Logs" Classes="text-page-title" />
          <TextBlock Text="Persisted service, torrent, and engine events."
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
        <Button Grid.Column="1"
                Classes="toolbar-action"
                Content="Clear Filters"
                Command="{Binding ClearFiltersCommand}" />
        <Button Grid.Column="2"
                Classes="toolbar-action"
                Content="Refresh"
                Command="{Binding RefreshCommand}" />
      </Grid>

      <Border Classes="panel-card">
        <Grid ColumnDefinitions="100,160,160,120,*" ColumnSpacing="10">
          <TextBox Text="{Binding Take}" Watermark="Take" />
          <TextBox Grid.Column="1" Text="{Binding Category}" Watermark="Category" />
          <TextBox Grid.Column="2" Text="{Binding EventType}" Watermark="Event Type" />
          <TextBox Grid.Column="3" Text="{Binding Level}" Watermark="Level" />
          <TextBox Grid.Column="4" Text="{Binding TorrentIdText}" Watermark="Torrent Id (GUID)" />
        </Grid>
      </Border>

      <Border Classes="panel-card"
              IsVisible="{Binding IsLoading}">
        <TextBlock Text="Loading logs..." />
      </Border>

      <Border Classes="panel-card"
              IsVisible="{Binding HasError}">
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   TextWrapping="Wrap" />
      </Border>

      <Border Classes="panel-card">
        <ItemsControl ItemsSource="{Binding Entries}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="diag:ActivityLogEntryDto">
              <Border BorderBrush="{DynamicResource RowDividerBrush}"
                      BorderThickness="0,0,0,1"
                      Padding="0,0,0,10"
                      Margin="0,0,0,10">
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="140,100,140,*" ColumnSpacing="10">
                    <TextBlock Text="{Binding OccurredAtUtc, StringFormat='{}{0:g}'}"
                               Classes="text-body-small"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Level}"
                               Classes="text-body-small" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Category}"
                               Classes="text-body-small" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding EventType}"
                               Classes="text-body-small" />
                  </Grid>
                  <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                  <SelectableTextBlock Text="{Binding DetailsJson}"
                                       Classes="text-body-small"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
