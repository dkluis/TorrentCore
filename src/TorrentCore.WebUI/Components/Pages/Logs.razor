@page "/logs"
@inject ITorrentCoreApiAdapter Api
@inject IOperatorFeedbackService Feedback
@inject IPageStateStore PageStateStore
@inject NavigationManager NavigationManager

<PageTitle>Logs</PageTitle>

<OperatorPage Kicker="Diagnostics"
              Title="Logs"
              Summary="TVMaze-style diagnostics table with one pager, explicit filter actions, and grid-contained scrolling."
              Class="logs-page"
              StatusLine="Shows recent activity from the current TorrentCore endpoint.">
    <HeaderActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   Disabled="_isRefreshing"
                   OnClick="RefreshAsync">
            Refresh
        </MudButton>
    </HeaderActions>

    <ChildContent>
        <StateView Mode="@_mode"
                   Title="Logs unavailable"
                   Message="@_errorMessage"
                   ActionText="Retry"
                   OnAction="RefreshAsync">
            <div class="dashboard-tab-content logs-tab-content">
                <div class="logs-grid">
                <OperatorCard Class="section-card logs-panel logs-panel--filters">
                    <div class="dashboard-panel-header">
                        <div>
                            <h2>Filters</h2>
                            <p class="dashboard-panel-copy">Refresh applies current filters. Clear resets inputs and reloads unfiltered logs.</p>
                        </div>
                        <div class="dashboard-inline-actions dashboard-inline-actions--compact">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="_isRefreshing"
                                       OnClick="RefreshAsync">
                                Refresh
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       Disabled="_isRefreshing"
                                       OnClick="ClearFiltersAsync">
                                Clear
                            </MudButton>
                        </div>
                    </div>

                    <div class="operations-filters">
                        <MudTextField T="string"
                                      Label="Search Message"
                                      Value="_state.SearchText"
                                      ValueChanged="OnSearchChanged"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />

                        <MudSelect T="string"
                                   Label="Level"
                                   Value="_state.PrimaryFilter"
                                   ValueChanged="OnLevelChanged"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Dense="true">
                            <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Trace")">Trace</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Debug")">Debug</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Information")">Information</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Warning")">Warning</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Error")">Error</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Critical")">Critical</MudSelectItem>
                        </MudSelect>

                        <MudTextField T="string"
                                      Label="Category"
                                      Value="_state.SecondaryFilter"
                                      ValueChanged="OnCategoryChanged"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />

                        <MudTextField T="string"
                                      Label="Torrent Id"
                                      Value="_torrentIdFilter"
                                      ValueChanged="OnTorrentIdChanged"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />

                        <MudTextField T="string"
                                      Label="From (Local Date/Time)"
                                      Value="_fromLocalFilter"
                                      ValueChanged="OnFromLocalChanged"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />

                        <MudTextField T="string"
                                      Label="To (Local Date/Time)"
                                      Value="_toLocalFilter"
                                      ValueChanged="OnToLocalChanged"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_filterValidationMessage))
                    {
                        <p class="dashboard-panel-copy tc-error-text">@_filterValidationMessage</p>
                    }
                </OperatorCard>

                <OperatorCard Class="section-card logs-panel logs-panel--table">
                    <div class="dashboard-panel-header">
                        <div>
                            <h2>Recent Activity</h2>
                            <p class="dashboard-panel-copy">@FilteredLogs.Count result(s) of @_allLogs.Count loaded</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_actionMessage))
                    {
                        <p class="@GetActionMessageClass()">@_actionMessage</p>
                    }

                    <div class="operations-table-frame logs-table-frame">
                            <MudTable T="ActivityLogEntryDto"
                                      Items="FilteredLogs"
                                      Dense="true"
                                      Hover="true"
                                      Bordered="true"
                                      Striped="true"
                                      FixedHeader="true"
                                      Loading="_isRefreshing"
                                      Breakpoint="Breakpoint.Md"
                                      Height="100%"
                                      RowsPerPage="@_state.PageSize"
                                      RowsPerPageChanged="OnRowsPerPageChanged"
                                      OnRowClick="OnLogRowClickAsync"
                                      RowClassFunc="GetLogRowClass"
                                      Class="operations-table logs-table"
                                      Elevation="0">
                                <HeaderContent>
                                    <MudTh>
                                        <MudTableSortLabel T="ActivityLogEntryDto" SortBy="@(log => log.OccurredAtUtc)">When</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="ActivityLogEntryDto" SortBy="@(log => log.Level)">Level</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="ActivityLogEntryDto" SortBy="@(log => log.Category)">Category</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="ActivityLogEntryDto" SortBy="@(log => log.EventType)">Event</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="ActivityLogEntryDto" SortBy="@(log => log.Message)">Message</MudTableSortLabel>
                                    </MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="When">@context.OccurredAtUtc.LocalDateTime.ToString("g")</MudTd>
                                    <MudTd DataLabel="Level">@context.Level</MudTd>
                                    <MudTd DataLabel="Category">@context.Category</MudTd>
                                    <MudTd DataLabel="Event">@context.EventType</MudTd>
                                    <MudTd DataLabel="Message" Class="operations-table-wrap">@context.Message</MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudText Typo="Typo.body2">No logs match the current filters.</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 250 }"
                                                   RowsPerPageString="Rows" />
                                </PagerContent>
                            </MudTable>
                    </div>
                </OperatorCard>

                <OperatorCard Class="section-card logs-panel logs-panel--detail">
                    <div class="dashboard-panel-header">
                        <div>
                            <h2>Selected Log Entry</h2>
                            <p class="dashboard-panel-copy">@BuildSelectionSummary()</p>
                        </div>
                    </div>

                    @if (SelectedLog is null)
                    {
                        <div class="dashboard-callout">
                            <p class="dashboard-callout-title">No log selected</p>
                            <p class="dashboard-callout-copy">Click a log row to inspect full details.</p>
                        </div>
                    }
                    else
                    {
                        <div class="dashboard-detail-grid">
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Log Entry Id</p>
                                <p class="dashboard-detail-value">@SelectedLog.LogEntryId</p>
                            </div>
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Occurred (Local)</p>
                                <p class="dashboard-detail-value">@SelectedLog.OccurredAtUtc.LocalDateTime.ToString("G")</p>
                            </div>
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Occurred (UTC)</p>
                                <p class="dashboard-detail-value">@SelectedLog.OccurredAtUtc.ToString("O")</p>
                            </div>
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Level</p>
                                <p class="dashboard-detail-value">@SelectedLog.Level</p>
                            </div>
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Category</p>
                                <p class="dashboard-detail-value">@SelectedLog.Category</p>
                            </div>
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Event</p>
                                <p class="dashboard-detail-value">@SelectedLog.EventType</p>
                            </div>
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Torrent Id</p>
                                <p class="dashboard-detail-value">@FormatGuid(SelectedLog.TorrentId)</p>
                            </div>
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Service Instance Id</p>
                                <p class="dashboard-detail-value">@FormatGuid(SelectedLog.ServiceInstanceId)</p>
                            </div>
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Trace Id</p>
                                <p class="dashboard-detail-value dashboard-detail-value--wrap">@ValueOrNotAvailable(SelectedLog.TraceId)</p>
                            </div>
                            <div class="dashboard-detail-item">
                                <p class="dashboard-detail-label">Message</p>
                                <p class="dashboard-detail-value dashboard-detail-value--wrap">@SelectedLog.Message</p>
                            </div>
                            <div class="dashboard-detail-item dashboard-detail-item--span-2">
                                <p class="dashboard-detail-label">Details JSON</p>
                                <p class="dashboard-detail-value dashboard-detail-value--wrap">@ValueOrNotAvailable(SelectedLog.DetailsJson)</p>
                            </div>
                        </div>
                    }
                </OperatorCard>
                </div>
            </div>
        </StateView>
    </ChildContent>
</OperatorPage>

@code {
    private const string StateKey = "logs:list";

    [Parameter]
    [SupplyParameterFromQuery(Name = "torrentId")]
    public string? TorrentId { get; set; }

    private readonly List<ActivityLogEntryDto> _allLogs = [];
    private StandardListPageState _state = new()
    {
        PageSize = 25,
    };
    private StateViewMode _mode = StateViewMode.Loading;
    private bool _isRefreshing;
    private string? _errorMessage;
    private string? _actionMessage;
    private bool _actionIsError;
    private string _torrentIdFilter = string.Empty;
    private string _fromLocalFilter = string.Empty;
    private string _toLocalFilter = string.Empty;
    private string? _filterValidationMessage;
    private long? _selectedLogEntryId;
    private ActivityLogEntryDto? _selectedLog;
    private bool _suppressFilterInputCallbacks;
    private string _appliedSearchText = string.Empty;
    private string _appliedLevelFilter = string.Empty;
    private string _appliedCategoryFilter = string.Empty;
    private string _appliedTorrentIdFilter = string.Empty;
    private string _appliedFromLocalFilter = string.Empty;
    private string _appliedToLocalFilter = string.Empty;

    private IReadOnlyList<ActivityLogEntryDto> FilteredLogs
    {
        get
        {
            IEnumerable<ActivityLogEntryDto> query = _allLogs;

            if (!string.IsNullOrWhiteSpace(_appliedSearchText))
            {
                query = query.Where(
                    log => log.Message.Contains(_appliedSearchText, StringComparison.OrdinalIgnoreCase) ||
                           log.EventType.Contains(_appliedSearchText, StringComparison.OrdinalIgnoreCase)
                );
            }

            if (!string.IsNullOrWhiteSpace(_appliedLevelFilter))
            {
                query = query.Where(log => string.Equals(log.Level, _appliedLevelFilter, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(_appliedCategoryFilter))
            {
                query = query.Where(log => log.Category.Contains(_appliedCategoryFilter, StringComparison.OrdinalIgnoreCase));
            }

            if (TryGetTorrentIdFilter(_appliedTorrentIdFilter, out var torrentIdFilter, out _) && torrentIdFilter is not null)
            {
                query = query.Where(log => log.TorrentId == torrentIdFilter);
            }

            if (TryGetDateTimeFilter(_appliedFromLocalFilter, out var fromUtcFilter, out _))
            {
                query = query.Where(log => log.OccurredAtUtc >= fromUtcFilter);
            }

            if (TryGetDateTimeFilter(_appliedToLocalFilter, out var toUtcFilter, out _))
            {
                query = query.Where(log => log.OccurredAtUtc <= toUtcFilter);
            }

            return query
                .OrderByDescending(log => log.OccurredAtUtc)
                .ToArray();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _state = PageStateStore.GetOrCreate(
            StateKey,
            () => new StandardListPageState
            {
                PageSize = 25,
            }
        );

        if (_state.PageSize <= 0)
        {
            _state.PageSize = 25;
        }

        _suppressFilterInputCallbacks = true;
        ResetFilters(includeTorrentIdQuery: true);
        ApplyDraftFilters();
        PersistState();
        ValidateFilters();
        await LoadAsync(showSuccessToast: false, showLoadingState: true);
        _suppressFilterInputCallbacks = false;
    }

    private async Task RefreshAsync()
    {
        ValidateFilters();
        if (!string.IsNullOrWhiteSpace(_filterValidationMessage))
        {
            Feedback.Error(_filterValidationMessage);
            _actionMessage = _filterValidationMessage;
            _actionIsError = true;
            return;
        }

        ApplyDraftFilters();
        await LoadAsync(showSuccessToast: true, showLoadingState: false);
    }

    private async Task LoadAsync(bool showSuccessToast, bool showLoadingState)
    {
        _isRefreshing = true;
        if (showLoadingState)
        {
            _mode = StateViewMode.Loading;
        }

        _errorMessage = null;
        _actionMessage = null;
        _actionIsError = false;
        PersistState();

        var logsResult = await Api.GetRecentLogsAsync(
            take: int.MaxValue
        );

        if (!logsResult.IsSuccess)
        {
            var errorMessage = logsResult.ErrorMessage ?? "Unable to load recent logs.";
            _errorMessage = errorMessage;
            _actionIsError = true;
            _actionMessage = errorMessage;
            _mode = _allLogs.Count == 0 ? StateViewMode.Error : StateViewMode.Ready;
            _isRefreshing = false;
            Feedback.Error(errorMessage);
            return;
        }

        _allLogs.Clear();
        if (logsResult.Value is not null)
        {
            _allLogs.AddRange(logsResult.Value);
        }

        if (_selectedLogEntryId is not null)
        {
            _selectedLog = _allLogs.FirstOrDefault(log => log.LogEntryId == _selectedLogEntryId.Value);
            if (_selectedLog is null)
            {
                _selectedLogEntryId = null;
            }
        }

        _mode = StateViewMode.Ready;
        _isRefreshing = false;

        if (showSuccessToast)
        {
            Feedback.Success("Logs refreshed.");
        }

        _actionMessage = $"Last refresh: {DateTimeOffset.Now.LocalDateTime:g} | Loaded {_allLogs.Count:n0} row(s).";
    }

    private Task OnRowsPerPageChanged(int value)
    {
        _state.PageSize = value;
        PersistState();
        _actionMessage = $"Rows per page: {value}";
        _actionIsError = false;
        return Task.CompletedTask;
    }

    private async Task ClearFiltersAsync()
    {
        _suppressFilterInputCallbacks = true;
        ResetFilters(includeTorrentIdQuery: false);
        ApplyDraftFilters();
        PersistState();
        NavigationManager.NavigateTo("/logs", replace: true);
        await LoadAsync(showSuccessToast: false, showLoadingState: false);

        // Enforce an explicit post-refresh reset to avoid stale input events
        // reapplying date values while Clear is processing.
        ResetFilters(includeTorrentIdQuery: false);
        ApplyDraftFilters();
        PersistState();
        ValidateFilters();
        _suppressFilterInputCallbacks = false;

        Feedback.Info("Filters cleared.");
        _actionMessage = "Filters cleared.";
        _actionIsError = false;
    }

    private void PersistState()
    {
        PageStateStore.Save(StateKey, _state);
    }

    private Task OnSearchChanged(string value)
    {
        if (_suppressFilterInputCallbacks)
        {
            return Task.CompletedTask;
        }

        _state.SearchText = value.Trim();
        PersistState();
        return Task.CompletedTask;
    }

    private Task OnLevelChanged(string value)
    {
        if (_suppressFilterInputCallbacks)
        {
            return Task.CompletedTask;
        }

        _state.PrimaryFilter = value;
        PersistState();
        return Task.CompletedTask;
    }

    private Task OnCategoryChanged(string value)
    {
        if (_suppressFilterInputCallbacks)
        {
            return Task.CompletedTask;
        }

        _state.SecondaryFilter = value.Trim();
        PersistState();
        return Task.CompletedTask;
    }

    private Task OnTorrentIdChanged(string value)
    {
        if (_suppressFilterInputCallbacks)
        {
            return Task.CompletedTask;
        }

        _torrentIdFilter = value.Trim();
        ValidateFilters();
        return Task.CompletedTask;
    }

    private Task OnFromLocalChanged(string value)
    {
        if (_suppressFilterInputCallbacks)
        {
            return Task.CompletedTask;
        }

        _fromLocalFilter = value.Trim();
        ValidateFilters();
        return Task.CompletedTask;
    }

    private Task OnToLocalChanged(string value)
    {
        if (_suppressFilterInputCallbacks)
        {
            return Task.CompletedTask;
        }

        _toLocalFilter = value.Trim();
        ValidateFilters();
        return Task.CompletedTask;
    }

    private void ResetFilters(bool includeTorrentIdQuery)
    {
        _state.SearchText = string.Empty;
        _state.PrimaryFilter = string.Empty;
        _state.SecondaryFilter = string.Empty;
        _torrentIdFilter = includeTorrentIdQuery ? (TorrentId ?? string.Empty).Trim() : string.Empty;
        _fromLocalFilter = string.Empty;
        _toLocalFilter = string.Empty;
        _filterValidationMessage = null;
        _selectedLogEntryId = null;
        _selectedLog = null;
    }

    private void ApplyDraftFilters()
    {
        _appliedSearchText = _state.SearchText;
        _appliedLevelFilter = _state.PrimaryFilter;
        _appliedCategoryFilter = _state.SecondaryFilter;
        _appliedTorrentIdFilter = _torrentIdFilter;
        _appliedFromLocalFilter = _fromLocalFilter;
        _appliedToLocalFilter = _toLocalFilter;
    }

    private Task OnLogRowClickAsync(TableRowClickEventArgs<ActivityLogEntryDto> args)
    {
        if (args.Item is null)
        {
            return Task.CompletedTask;
        }

        _selectedLogEntryId = args.Item.LogEntryId;
        _selectedLog = args.Item;
        return Task.CompletedTask;
    }

    private string GetActionMessageClass()
    {
        return _actionIsError ? "dashboard-panel-copy tc-error-text" : "dashboard-panel-copy";
    }

    private string GetLogRowClass(ActivityLogEntryDto log, int rowNumber)
    {
        return _selectedLogEntryId == log.LogEntryId ? "operations-table-row--selected" : string.Empty;
    }

    private ActivityLogEntryDto? SelectedLog => _selectedLog;

    private string BuildSelectionSummary()
    {
        if (SelectedLog is null)
        {
            return "No active selection.";
        }

        return $"{SelectedLog.Level} | {SelectedLog.Category} | {SelectedLog.EventType}";
    }

    private static string ValueOrNotAvailable(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "N/A" : value;
    }

    private static string FormatGuid(Guid? value)
    {
        return value?.ToString("D") ?? "N/A";
    }

    private bool TryGetTorrentIdFilter(out Guid? torrentIdFilter)
    {
        return TryGetTorrentIdFilter(_torrentIdFilter, out torrentIdFilter, out _);
    }

    private bool TryGetTorrentIdFilter(out Guid? torrentIdFilter, out string? errorMessage)
    {
        return TryGetTorrentIdFilter(_torrentIdFilter, out torrentIdFilter, out errorMessage);
    }

    private static bool TryGetTorrentIdFilter(string value, out Guid? torrentIdFilter, out string? errorMessage)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            torrentIdFilter = null;
            errorMessage = null;
            return true;
        }

        if (Guid.TryParse(value, out var parsed))
        {
            torrentIdFilter = parsed;
            errorMessage = null;
            return true;
        }

        torrentIdFilter = null;
        errorMessage = "Torrent Id filter must be a valid GUID.";
        return false;
    }

    private bool TryGetFromUtcFilter(out DateTimeOffset fromUtc)
    {
        return TryGetDateTimeFilter(_fromLocalFilter, out fromUtc, out _);
    }

    private bool TryGetToUtcFilter(out DateTimeOffset toUtc)
    {
        return TryGetDateTimeFilter(_toLocalFilter, out toUtc, out _);
    }

    private static bool TryGetDateTimeFilter(string value, out DateTimeOffset utcValue, out string? errorMessage)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            utcValue = default;
            errorMessage = null;
            return false;
        }

        if (DateTimeOffset.TryParse(
                value,
                System.Globalization.CultureInfo.CurrentCulture,
                System.Globalization.DateTimeStyles.AllowWhiteSpaces | System.Globalization.DateTimeStyles.AssumeLocal,
                out var parsed))
        {
            utcValue = parsed.ToUniversalTime();
            errorMessage = null;
            return true;
        }

        utcValue = default;
        errorMessage = "Date/time filters must be valid local date-time values.";
        return false;
    }

    private void ValidateFilters()
    {
        _filterValidationMessage = null;

        if (!TryGetTorrentIdFilter(out _, out var torrentIdError))
        {
            _filterValidationMessage = torrentIdError;
            return;
        }

        var hasFrom = TryGetDateTimeFilter(_fromLocalFilter, out var fromUtc, out var fromError);
        if (fromError is not null)
        {
            _filterValidationMessage = fromError;
            return;
        }

        var hasTo = TryGetDateTimeFilter(_toLocalFilter, out var toUtc, out var toError);
        if (toError is not null)
        {
            _filterValidationMessage = toError;
            return;
        }

        if (hasFrom && hasTo && fromUtc > toUtc)
        {
            _filterValidationMessage = "'From' must be earlier than or equal to 'To'.";
        }
    }
}
