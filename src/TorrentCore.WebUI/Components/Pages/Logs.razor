@page "/logs"
@inject ITorrentCoreApiAdapter Api
@inject IOperatorFeedbackService Feedback
@inject IPageStateStore PageStateStore

<PageTitle>Logs</PageTitle>

<OperatorPage Kicker="Diagnostics"
              Title="Logs"
              Summary="TVMaze-style diagnostics table with one pager, explicit filter actions, and grid-contained scrolling."
              Class="logs-page"
              StatusLine="Shows recent activity from the current TorrentCore endpoint.">
    <HeaderActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   Disabled="_isRefreshing"
                   OnClick="RefreshAsync">
            Refresh
        </MudButton>
    </HeaderActions>

    <ChildContent>
        <StateView Mode="@_mode"
                   Title="Logs unavailable"
                   Message="@_errorMessage"
                   ActionText="Retry"
                   OnAction="RefreshAsync">
            <div class="dashboard-tab-content logs-tab-content">
                <div class="logs-grid">
                <OperatorCard Class="section-card logs-panel logs-panel--filters">
                    <div class="dashboard-panel-header">
                        <div>
                            <h2>Filters</h2>
                            <p class="dashboard-panel-copy">Refresh applies current filters. Clear resets inputs and reloads unfiltered logs.</p>
                        </div>
                        <div class="dashboard-inline-actions dashboard-inline-actions--compact">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="_isRefreshing"
                                       OnClick="RefreshAsync">
                                Refresh
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       Disabled="_isRefreshing"
                                       OnClick="ClearFiltersAsync">
                                Clear
                            </MudButton>
                        </div>
                    </div>

                    <div class="operations-filters">
                        <MudTextField T="string"
                                      Label="Search Message"
                                      Value="_state.SearchText"
                                      ValueChanged="OnSearchChanged"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />

                        <MudSelect T="string"
                                   Label="Level"
                                   Value="_state.PrimaryFilter"
                                   ValueChanged="OnLevelChanged"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Dense="true">
                            <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Trace")">Trace</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Debug")">Debug</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Information")">Information</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Warning")">Warning</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Error")">Error</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Critical")">Critical</MudSelectItem>
                        </MudSelect>

                        <MudTextField T="string"
                                      Label="Category"
                                      Value="_state.SecondaryFilter"
                                      ValueChanged="OnCategoryChanged"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />
                    </div>
                </OperatorCard>

                <OperatorCard Class="section-card logs-panel logs-panel--table">
                    <div class="dashboard-panel-header">
                        <div>
                            <h2>Recent Activity</h2>
                            <p class="dashboard-panel-copy">@FilteredLogs.Count result(s)</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_actionMessage))
                    {
                        <p class="@GetActionMessageClass()">@_actionMessage</p>
                    }

                    <div class="operations-table-frame logs-table-frame">
                            <MudTable Items="FilteredLogs"
                                      Dense="true"
                                      Hover="true"
                                      Bordered="true"
                                      Striped="true"
                                      FixedHeader="true"
                                      Loading="_isRefreshing"
                                      Breakpoint="Breakpoint.Md"
                                      Height="100%"
                                      RowsPerPage="@_state.PageSize"
                                      RowsPerPageChanged="OnRowsPerPageChanged"
                                      Class="operations-table logs-table"
                                      Elevation="0">
                                <HeaderContent>
                                    <MudTh>When</MudTh>
                                    <MudTh>Level</MudTh>
                                    <MudTh>Category</MudTh>
                                    <MudTh>Event</MudTh>
                                    <MudTh>Message</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="When">@context.OccurredAtUtc.LocalDateTime.ToString("g")</MudTd>
                                    <MudTd DataLabel="Level">@context.Level</MudTd>
                                    <MudTd DataLabel="Category">@context.Category</MudTd>
                                    <MudTd DataLabel="Event">@context.EventType</MudTd>
                                    <MudTd DataLabel="Message" Class="operations-table-wrap">@context.Message</MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudText Typo="Typo.body2">No logs match the current filters.</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 250 }"
                                                   RowsPerPageString="Rows" />
                                </PagerContent>
                            </MudTable>
                    </div>
                </OperatorCard>
                </div>
            </div>
        </StateView>
    </ChildContent>
</OperatorPage>

@code {
    private const string StateKey = "logs:list";

    private readonly List<ActivityLogEntryDto> _allLogs = [];
    private StandardListPageState _state = new()
    {
        PageSize = 25,
    };
    private StateViewMode _mode = StateViewMode.Loading;
    private bool _isRefreshing;
    private string? _errorMessage;
    private string? _actionMessage;
    private bool _actionIsError;

    private IReadOnlyList<ActivityLogEntryDto> FilteredLogs
    {
        get
        {
            IEnumerable<ActivityLogEntryDto> query = _allLogs;

            if (!string.IsNullOrWhiteSpace(_state.SearchText))
            {
                query = query.Where(
                    log => log.Message.Contains(_state.SearchText, StringComparison.OrdinalIgnoreCase) ||
                           log.EventType.Contains(_state.SearchText, StringComparison.OrdinalIgnoreCase)
                );
            }

            if (!string.IsNullOrWhiteSpace(_state.PrimaryFilter))
            {
                query = query.Where(log => string.Equals(log.Level, _state.PrimaryFilter, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(_state.SecondaryFilter))
            {
                query = query.Where(log => log.Category.Contains(_state.SecondaryFilter, StringComparison.OrdinalIgnoreCase));
            }

            return query
                .OrderByDescending(log => log.OccurredAtUtc)
                .ToArray();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _state = PageStateStore.GetOrCreate(
            StateKey,
            () => new StandardListPageState
            {
                PageSize = 25,
            }
        );

        if (_state.PageSize <= 0)
        {
            _state.PageSize = 25;
        }

        await LoadAsync(showSuccessToast: false, showLoadingState: true);
    }

    private async Task RefreshAsync()
    {
        await LoadAsync(showSuccessToast: true, showLoadingState: false);
    }

    private async Task LoadAsync(bool showSuccessToast, bool showLoadingState)
    {
        _isRefreshing = true;
        if (showLoadingState)
        {
            _mode = StateViewMode.Loading;
        }

        _errorMessage = null;
        _actionMessage = null;
        _actionIsError = false;
        PersistState();

        var logsResult = await Api.GetRecentLogsAsync(
            take: int.MaxValue
        );

        if (!logsResult.IsSuccess)
        {
            var errorMessage = logsResult.ErrorMessage ?? "Unable to load recent logs.";
            _errorMessage = errorMessage;
            _actionIsError = true;
            _actionMessage = errorMessage;
            _mode = _allLogs.Count == 0 ? StateViewMode.Error : StateViewMode.Ready;
            _isRefreshing = false;
            Feedback.Error(errorMessage);
            return;
        }

        _allLogs.Clear();
        if (logsResult.Value is not null)
        {
            _allLogs.AddRange(logsResult.Value);
        }

        _mode = _allLogs.Count == 0 ? StateViewMode.Empty : StateViewMode.Ready;
        _isRefreshing = false;

        if (showSuccessToast)
        {
            Feedback.Success("Logs refreshed.");
        }

        _actionMessage = $"Last refresh: {DateTimeOffset.Now.LocalDateTime:g}";
    }

    private Task OnRowsPerPageChanged(int value)
    {
        _state.PageSize = value;
        PersistState();
        _actionMessage = $"Rows per page: {value}";
        _actionIsError = false;
        return Task.CompletedTask;
    }

    private async Task ClearFiltersAsync()
    {
        _state.SearchText = string.Empty;
        _state.PrimaryFilter = string.Empty;
        _state.SecondaryFilter = string.Empty;
        PersistState();
        await LoadAsync(showSuccessToast: false, showLoadingState: false);
        Feedback.Info("Filters cleared.");
        _actionMessage = "Filters cleared.";
        _actionIsError = false;
    }

    private void PersistState()
    {
        PageStateStore.Save(StateKey, _state);
    }

    private Task OnSearchChanged(string value)
    {
        _state.SearchText = value.Trim();
        PersistState();
        return Task.CompletedTask;
    }

    private Task OnLevelChanged(string value)
    {
        _state.PrimaryFilter = value;
        PersistState();
        return Task.CompletedTask;
    }

    private Task OnCategoryChanged(string value)
    {
        _state.SecondaryFilter = value.Trim();
        PersistState();
        return Task.CompletedTask;
    }

    private string GetActionMessageClass()
    {
        return _actionIsError ? "dashboard-panel-copy tc-error-text" : "dashboard-panel-copy";
    }
}
