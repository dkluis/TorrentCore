@page "/service-connection"
@inject WebServiceConnectionManager ConnectionManager
@inject IOperatorFeedbackService Feedback

<PageTitle>Service Connection</PageTitle>

<OperatorPage Kicker="Connectivity"
              Title="Service Connection"
              Summary="Shared endpoint persistence for TorrentCore.WebUI with test/save/recheck actions."
              StatusLine="Endpoint is stored in Config/service-connection.json for this host.">
    <ChildContent>
        <StateView Mode="@_mode"
                   Title="Service connection unavailable"
                   Message="@_errorMessage"
                   ActionText="Retry"
                   OnAction="LoadAsync">
            <OperatorCardGrid>
                <OperatorCard>
                    <p class="section-card-eyebrow">Current Endpoint</p>
                    <h2 class="tc-break">@(_status?.BaseUrl ?? "Not configured")</h2>
                    <p>
                        Reachability:
                        <span class="@GetReachabilityClass(_status)">
                            @GetReachabilityText(_status)
                        </span>
                    </p>
                    <p>Last checked: @GetCheckedAtText(_status)</p>
                    @if (!string.IsNullOrWhiteSpace(_status?.ErrorMessage))
                    {
                        <p class="dashboard-panel-copy">@_status.ErrorMessage</p>
                    }
                </OperatorCard>

                <OperatorCard>
                    <p class="section-card-eyebrow">Update Endpoint</p>
                    <MudTextField T="string"
                                  Label="Service Base URL"
                                  Value="_baseUrl"
                                  ValueChanged="OnBaseUrlChanged"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Placeholder="http://torrentcore-service.local:5050/" />
                    <p class="dashboard-panel-copy">Use the host/IP for the machine running `TorrentCore.Service`.</p>

                    <div class="dashboard-inline-actions dashboard-inline-actions--compact">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="@(_isTesting || _isSaving)"
                                   OnClick="TestAsync">
                            @(_isTesting ? "Testing..." : "Test")
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="@(_isTesting || _isSaving)"
                                   OnClick="SaveAsync">
                            @(_isSaving ? "Saving..." : "Save")
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   Size="Size.Small"
                                   Disabled="@(_isTesting || _isSaving)"
                                   OnClick="RefreshStatusAsync">
                            Recheck
                        </MudButton>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_actionMessage))
                    {
                        <p class="@GetActionMessageClass()">@_actionMessage</p>
                    }
                </OperatorCard>
            </OperatorCardGrid>
        </StateView>
    </ChildContent>
</OperatorPage>

@code {
    private bool _isTesting;
    private bool _isSaving;
    private string _baseUrl = string.Empty;
    private string? _errorMessage;
    private string? _actionMessage;
    private bool _actionIsError;
    private StateViewMode _mode = StateViewMode.Loading;
    private TorrentCoreConnectionProbeResult? _status;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _mode = StateViewMode.Loading;
        _errorMessage = null;

        try
        {
            _status = await ConnectionManager.GetStatusAsync();
            _baseUrl = _status.BaseUrl ?? ConnectionManager.DefaultBaseUrl ?? string.Empty;
            _mode = StateViewMode.Ready;
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
            _mode = StateViewMode.Error;
        }
    }

    private async Task RefreshStatusAsync()
    {
        _actionMessage = null;
        _actionIsError = false;
        _actionMessage = "Rechecking current endpoint...";
        try
        {
            _status = await ConnectionManager.RefreshAsync();
            _actionIsError = !_status.IsReachable;
            _actionMessage = _status.IsReachable
                ? "Recheck complete: current endpoint is reachable."
                : _status.ErrorMessage ?? "Recheck complete: endpoint is unavailable.";

            if (_status.IsReachable)
            {
                Feedback.Success("Recheck complete.");
            }
            else
            {
                Feedback.Warning("Recheck complete: endpoint unavailable.");
            }
        }
        catch (Exception exception)
        {
            _actionIsError = true;
            _actionMessage = $"Recheck failed: {exception.Message}";
            Feedback.Error(_actionMessage);
        }
    }

    private async Task TestAsync()
    {
        _isTesting = true;
        _actionMessage = null;
        _actionIsError = false;
        _actionMessage = "Testing endpoint...";
        try
        {
            var result = await ConnectionManager.TestAsync(_baseUrl);
            _status = result;

            if (result.IsReachable)
            {
                _actionIsError = false;
                _actionMessage = $"Test passed for {result.BaseUrl}.";
                Feedback.Success("Connection test passed.");
                return;
            }

            _actionIsError = true;
            _actionMessage = result.ErrorMessage ?? "Connection test failed.";
            Feedback.Error(_actionMessage);
        }
        catch (Exception exception)
        {
            _actionIsError = true;
            _actionMessage = $"Connection test failed: {exception.Message}";
            Feedback.Error(_actionMessage);
        }
        finally
        {
            _isTesting = false;
        }
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _actionMessage = null;
        _actionIsError = false;
        _actionMessage = "Saving endpoint...";
        try
        {
            var result = await ConnectionManager.SaveAsync(_baseUrl);
            _status = result;

            if (!result.IsReachable)
            {
                _actionIsError = true;
                _actionMessage = result.ErrorMessage ?? "Configured endpoint is unreachable.";
                Feedback.Error(_actionMessage);
                return;
            }

            _baseUrl = result.BaseUrl ?? _baseUrl;
            _actionIsError = false;
            _actionMessage = $"Saved endpoint: {_baseUrl}";
            Feedback.Success("Shared endpoint saved and applied.");
        }
        catch (Exception exception)
        {
            _actionIsError = true;
            _actionMessage = $"Save failed: {exception.Message}";
            Feedback.Error(_actionMessage);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private Task OnBaseUrlChanged(string value)
    {
        _baseUrl = value.Trim();
        return Task.CompletedTask;
    }

    private static string GetReachabilityClass(TorrentCoreConnectionProbeResult? status)
    {
        if (status is null)
        {
            return "dashboard-status-pill dashboard-status-pill--unknown";
        }

        return status.IsReachable
            ? "dashboard-status-pill dashboard-status-pill--healthy"
            : "dashboard-status-pill dashboard-status-pill--unhealthy";
    }

    private static string GetReachabilityText(TorrentCoreConnectionProbeResult? status)
    {
        if (status is null)
        {
            return "Unknown";
        }

        return status.IsReachable ? "Reachable" : "Unavailable";
    }

    private static string GetCheckedAtText(TorrentCoreConnectionProbeResult? status)
    {
        return status?.CheckedAtUtc.LocalDateTime.ToString("g") ?? "Not checked yet";
    }

    private string GetActionMessageClass()
    {
        return _actionIsError ? "dashboard-panel-copy tc-error-text" : "dashboard-panel-copy";
    }
}
