                                                <div class="settings-field-block settings-category-field settings-category-field--short">
                                                    <SettingHelpTrigger Content="@SettingsHelpCatalog.CategoryCallbackLabel" />
                                                    <MudTextField T="string"
                                                                  Value="category.CallbackLabel"
                                                                  ValueChanged="value => UpdateCategory(value, category, (item, next) => item.CallbackLabel = next)"
                                                                  Variant="Variant.Outlined"
