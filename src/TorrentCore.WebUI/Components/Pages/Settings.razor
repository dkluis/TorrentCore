@page "/settings"
@using TorrentCore.Contracts.Categories
@using TorrentCore.Contracts.Host
@inject ITorrentCoreApiAdapter Api
@inject IOperatorFeedbackService Feedback
@inject IDialogService DialogService

<PageTitle>Settings</PageTitle>

<OperatorPage Kicker="Administration"
              Title="Settings"
              Summary="Compact grouped editor for runtime policy, engine limits, callback handling, and category routing."
              Class="settings-page"
              StatusLine="@BuildStatusLine()">
    <HeaderActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   Disabled="@(_isRefreshing || _savingGroupKey is not null)"
                   OnClick="RefreshAsync">
            Refresh
        </MudButton>
    </HeaderActions>

    <ChildContent>
        <StateView Mode="@_mode"
                   Title="Settings unavailable"
                   Message="@_errorMessage"
                   ActionText="Retry"
                   OnAction="RefreshAsync">
            @if (_runtimeSnapshot is not null)
            {
                <div class="settings-page-layout">
                    <OperatorCard Class="settings-summary-card">
                        <div class="settings-summary-line">
                            <div class="settings-summary-chip">
                                <span class="settings-summary-label">Runtime</span>
                                <strong>@_runtimeSnapshot.EngineRuntime</strong>
                                <span class="settings-summary-meta">@(_runtimeSnapshot.PartialFilesEnabled ? $"Partial On ({_runtimeSnapshot.PartialFileSuffix})" : "Partial Off")</span>
                            </div>

                            <div class="settings-summary-chip">
                                <span class="settings-summary-label">Apply State</span>
                                <strong>@(_runtimeSnapshot.EngineSettingsRequireRestart ? "Restart Required" : "Applied")</strong>
                                <span class="settings-summary-meta">Overrides: @(_runtimeSnapshot.UsesPersistedOverrides ? "Yes" : "No")</span>
                            </div>

                            <div class="settings-summary-chip">
                                <span class="settings-summary-label">Applied Throttles</span>
                                <strong>@_runtimeSnapshot.AppliedEngineMaximumConnections conn / @_runtimeSnapshot.AppliedEngineMaximumHalfOpenConnections half-open</strong>
                                <span class="settings-summary-meta">Down @FormatRate(_runtimeSnapshot.AppliedEngineMaximumDownloadRateBytesPerSecond) | Up @FormatRate(_runtimeSnapshot.AppliedEngineMaximumUploadRateBytesPerSecond)</span>
                            </div>

                            <div class="settings-summary-chip">
                                <span class="settings-summary-label">Routing</span>
                                <strong>@_categories.Count categories</strong>
                                <span class="settings-summary-meta">Callback @(_callback.CompletionCallbackEnabled ? "On" : "Off") | Completed logs @(_lifecycle.DeleteLogsForCompletedTorrents ? "On" : "Off")</span>
                            </div>
                        </div>
                    </OperatorCard>

                    <div class="settings-editor-grid">
                        <OperatorCard Class="settings-group-card">
                            <div class="settings-group-shell">
                                @if (IsGroupBlocked(SettingsGroupKey.Lifecycle))
                                {
                                    <button type="button"
                                            class="settings-group-blocker"
                                            @onclick="() => OnBlockedGroupClickedAsync(SettingsGroupKey.Lifecycle)">
                                        <span class="settings-group-blocker-copy">
                                            Resolve @GetGroupTitle(_dirtyGroupKey!.Value) before editing this section.
                                        </span>
                                    </button>
                                }

                                <div class="dashboard-panel-header">
                                    <div>
                                        <h2>Lifecycle &amp; Cleanup</h2>
                                        <p class="dashboard-panel-copy">Live seeding policy and completed-torrent cleanup behavior.</p>
                                    </div>
                                    <div class="dashboard-inline-actions dashboard-inline-actions--compact settings-group-actions">
                                        <span class="@GetGroupStateClass(SettingsGroupKey.Lifecycle)">@GetGroupStateText(SettingsGroupKey.Lifecycle)</span>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Lifecycle) || IsBusy)"
                                                   OnClick="() => DiscardGroupAsync(SettingsGroupKey.Lifecycle)">
                                            Discard
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Lifecycle) || IsBusy)"
                                                   OnClick="() => SaveGroupAsync(SettingsGroupKey.Lifecycle)">
                                            Save
                                        </MudButton>
                                    </div>
                                </div>

                                <div class="settings-field-grid">
                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.SeedingStopMode" />
                                        <MudSelect T="string"
                                                   Value="_lifecycle.SeedingStopMode"
                                                   ValueChanged="value => UpdateLifecycle(value, (group, next) => group.SeedingStopMode = next)"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Dense="true">
                                            @foreach (var seedingMode in SeedingModes)
                                            {
                                                <MudSelectItem T="string" Value="@seedingMode">@seedingMode</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.SeedingStopRatio" />
                                        <MudNumericField T="double"
                                                         Value="_lifecycle.SeedingStopRatio"
                                                         ValueChanged="value => UpdateLifecycle(value, (group, next) => group.SeedingStopRatio = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="0.01"
                                                         Step="0.01"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.SeedingStopMinutes" />
                                        <MudNumericField T="int"
                                                         Value="_lifecycle.SeedingStopMinutes"
                                                         ValueChanged="value => UpdateLifecycle(value, (group, next) => group.SeedingStopMinutes = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletedTorrentCleanupMode" />
                                        <MudSelect T="string"
                                                   Value="_lifecycle.CompletedTorrentCleanupMode"
                                                   ValueChanged="value => UpdateLifecycle(value, (group, next) => group.CompletedTorrentCleanupMode = next)"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Dense="true">
                                            @foreach (var cleanupMode in CleanupModes)
                                            {
                                                <MudSelectItem T="string" Value="@cleanupMode">@cleanupMode</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletedTorrentCleanupMinutes" />
                                        <MudNumericField T="int"
                                                         Value="_lifecycle.CompletedTorrentCleanupMinutes"
                                                         ValueChanged="value => UpdateLifecycle(value, (group, next) => group.CompletedTorrentCleanupMinutes = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="0"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block settings-field-block--toggle">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.DeleteLogsForCompletedTorrents" />
                                        <MudCheckBox T="bool"
                                                     Value="_lifecycle.DeleteLogsForCompletedTorrents"
                                                     ValueChanged="value => UpdateLifecycle(value, (group, next) => group.DeleteLogsForCompletedTorrents = next)"
                                                     Dense="true"
                                                     Color="Color.Primary" />
                                    </div>
                                </div>

                                <p class="dashboard-panel-copy">
                                    Completed-log deletion uses the same completion-age window and only applies after a successful completion. Automatic cleanup never deletes downloaded data.
                                </p>
                            </div>
                        </OperatorCard>

                        <OperatorCard Class="settings-group-card">
                            <div class="settings-group-shell">
                                @if (IsGroupBlocked(SettingsGroupKey.Queue))
                                {
                                    <button type="button"
                                            class="settings-group-blocker"
                                            @onclick="() => OnBlockedGroupClickedAsync(SettingsGroupKey.Queue)">
                                        <span class="settings-group-blocker-copy">
                                            Resolve @GetGroupTitle(_dirtyGroupKey!.Value) before editing this section.
                                        </span>
                                    </button>
                                }

                                <div class="dashboard-panel-header">
                                    <div>
                                        <h2>Queue &amp; Recovery</h2>
                                        <p class="dashboard-panel-copy">Live queue limits, stale metadata recovery, and connection-failure log throttling.</p>
                                    </div>
                                    <div class="dashboard-inline-actions dashboard-inline-actions--compact settings-group-actions">
                                        <span class="@GetGroupStateClass(SettingsGroupKey.Queue)">@GetGroupStateText(SettingsGroupKey.Queue)</span>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Queue) || IsBusy)"
                                                   OnClick="() => DiscardGroupAsync(SettingsGroupKey.Queue)">
                                            Discard
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Queue) || IsBusy)"
                                                   OnClick="() => SaveGroupAsync(SettingsGroupKey.Queue)">
                                            Save
                                        </MudButton>
                                    </div>
                                </div>

                                <div class="settings-field-grid">
                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.MaxActiveMetadataResolutions" />
                                        <MudNumericField T="int"
                                                         Value="_queue.MaxActiveMetadataResolutions"
                                                         ValueChanged="value => UpdateQueue(value, (group, next) => group.MaxActiveMetadataResolutions = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.MaxActiveDownloads" />
                                        <MudNumericField T="int"
                                                         Value="_queue.MaxActiveDownloads"
                                                         ValueChanged="value => UpdateQueue(value, (group, next) => group.MaxActiveDownloads = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.MetadataRefreshStaleSeconds" />
                                        <MudNumericField T="int"
                                                         Value="_queue.MetadataRefreshStaleSeconds"
                                                         ValueChanged="value => UpdateQueue(value, (group, next) => group.MetadataRefreshStaleSeconds = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.MetadataRefreshRestartDelaySeconds" />
                                        <MudNumericField T="int"
                                                         Value="_queue.MetadataRefreshRestartDelaySeconds"
                                                         ValueChanged="value => UpdateQueue(value, (group, next) => group.MetadataRefreshRestartDelaySeconds = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.EngineConnectionFailureLogBurstLimit" />
                                        <MudNumericField T="int"
                                                         Value="_queue.EngineConnectionFailureLogBurstLimit"
                                                         ValueChanged="value => UpdateQueue(value, (group, next) => group.EngineConnectionFailureLogBurstLimit = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.EngineConnectionFailureLogWindowSeconds" />
                                        <MudNumericField T="int"
                                                         Value="_queue.EngineConnectionFailureLogWindowSeconds"
                                                         ValueChanged="value => UpdateQueue(value, (group, next) => group.EngineConnectionFailureLogWindowSeconds = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>
                                </div>

                                <p class="dashboard-panel-copy">
                                    New magnets are accepted immediately; queue limits only control execution. Recovery first refreshes discovery, then escalates if the torrent stays cold.
                                </p>
                            </div>
                        </OperatorCard>

                        <OperatorCard Class="settings-group-card">
                            <div class="settings-group-shell">
                                @if (IsGroupBlocked(SettingsGroupKey.Engine))
                                {
                                    <button type="button"
                                            class="settings-group-blocker"
                                            @onclick="() => OnBlockedGroupClickedAsync(SettingsGroupKey.Engine)">
                                        <span class="settings-group-blocker-copy">
                                            Resolve @GetGroupTitle(_dirtyGroupKey!.Value) before editing this section.
                                        </span>
                                    </button>
                                }

                                <div class="dashboard-panel-header">
                                    <div>
                                        <h2>Engine Throttles</h2>
                                        <p class="dashboard-panel-copy">Saved engine host limits. These values apply after TorrentCore.Service restarts.</p>
                                    </div>
                                    <div class="dashboard-inline-actions dashboard-inline-actions--compact settings-group-actions">
                                        <span class="@GetGroupStateClass(SettingsGroupKey.Engine)">@GetGroupStateText(SettingsGroupKey.Engine)</span>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Engine) || IsBusy)"
                                                   OnClick="() => DiscardGroupAsync(SettingsGroupKey.Engine)">
                                            Discard
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Engine) || IsBusy)"
                                                   OnClick="() => SaveGroupAsync(SettingsGroupKey.Engine)">
                                            Save
                                        </MudButton>
                                    </div>
                                </div>

                                <div class="settings-readonly-grid">
                                    <div class="settings-readonly-item">
                                        <span class="settings-readonly-label">Applied max connections</span>
                                        <strong>@_runtimeSnapshot.AppliedEngineMaximumConnections</strong>
                                    </div>
                                    <div class="settings-readonly-item">
                                        <span class="settings-readonly-label">Applied half-open</span>
                                        <strong>@_runtimeSnapshot.AppliedEngineMaximumHalfOpenConnections</strong>
                                    </div>
                                    <div class="settings-readonly-item">
                                        <span class="settings-readonly-label">Applied max download</span>
                                        <strong>@FormatRate(_runtimeSnapshot.AppliedEngineMaximumDownloadRateBytesPerSecond)</strong>
                                    </div>
                                    <div class="settings-readonly-item">
                                        <span class="settings-readonly-label">Applied max upload</span>
                                        <strong>@FormatRate(_runtimeSnapshot.AppliedEngineMaximumUploadRateBytesPerSecond)</strong>
                                    </div>
                                </div>

                                <div class="settings-field-grid">
                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.EngineMaximumConnections" />
                                        <MudNumericField T="int"
                                                         Value="_engine.EngineMaximumConnections"
                                                         ValueChanged="value => UpdateEngine(value, (group, next) => group.EngineMaximumConnections = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.EngineMaximumHalfOpenConnections" />
                                        <MudNumericField T="int"
                                                         Value="_engine.EngineMaximumHalfOpenConnections"
                                                         ValueChanged="value => UpdateEngine(value, (group, next) => group.EngineMaximumHalfOpenConnections = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.EngineMaximumDownloadRateBytesPerSecond" />
                                        <MudNumericField T="int"
                                                         Value="_engine.EngineMaximumDownloadRateBytesPerSecond"
                                                         ValueChanged="value => UpdateEngine(value, (group, next) => group.EngineMaximumDownloadRateBytesPerSecond = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="0"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.EngineMaximumUploadRateBytesPerSecond" />
                                        <MudNumericField T="int"
                                                         Value="_engine.EngineMaximumUploadRateBytesPerSecond"
                                                         ValueChanged="value => UpdateEngine(value, (group, next) => group.EngineMaximumUploadRateBytesPerSecond = next)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="0"
                                                         Step="1"
                                                         Immediate="true" />
                                    </div>
                                </div>

                                <p class="dashboard-panel-copy">
                                    Use <strong>0</strong> for unlimited download or upload rate. Restart-required values are shown separately from the engine's currently applied limits.
                                </p>
                            </div>
                        </OperatorCard>

                        <OperatorCard Class="settings-group-card">
                            <div class="settings-group-shell">
                                @if (IsGroupBlocked(SettingsGroupKey.Callback))
                                {
                                    <button type="button"
                                            class="settings-group-blocker"
                                            @onclick="() => OnBlockedGroupClickedAsync(SettingsGroupKey.Callback)">
                                        <span class="settings-group-blocker-copy">
                                            Resolve @GetGroupTitle(_dirtyGroupKey!.Value) before editing this section.
                                        </span>
                                    </button>
                                }

                                <div class="dashboard-panel-header">
                                    <div>
                                        <h2>Completion Callback</h2>
                                        <p class="dashboard-panel-copy">Shared TVMaze callback launcher, process timeouts, and optional override values.</p>
                                    </div>
                                    <div class="dashboard-inline-actions dashboard-inline-actions--compact settings-group-actions">
                                        <span class="@GetGroupStateClass(SettingsGroupKey.Callback)">@GetGroupStateText(SettingsGroupKey.Callback)</span>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Callback) || IsBusy)"
                                                   OnClick="() => DiscardGroupAsync(SettingsGroupKey.Callback)">
                                            Discard
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Callback) || IsBusy)"
                                                   OnClick="() => SaveGroupAsync(SettingsGroupKey.Callback)">
                                            Save
                                        </MudButton>
                                    </div>
                                </div>

                                <div class="settings-field-block settings-field-block--toggle">
                                    <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletionCallbackEnabled" />
                                    <MudCheckBox T="bool"
                                                 Value="_callback.CompletionCallbackEnabled"
                                                 ValueChanged="value => UpdateCallback(value, (group, next) => group.CompletionCallbackEnabled = next)"
                                                 Dense="true"
                                                 Color="Color.Primary" />
                                </div>

                                <div class="settings-field-stack">
                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletionCallbackCommandPath" />
                                        <MudTextField T="string"
                                                      Value="_callback.CompletionCallbackCommandPath"
                                                      ValueChanged="value => UpdateCallback(value, (group, next) => group.CompletionCallbackCommandPath = next)"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true" />
                                    </div>

                                    <div class="settings-field-grid settings-field-grid--pair">
                                        <div class="settings-field-block">
                                            <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletionCallbackTimeoutSeconds" />
                                            <MudNumericField T="int"
                                                             Value="_callback.CompletionCallbackTimeoutSeconds"
                                                             ValueChanged="value => UpdateCallback(value, (group, next) => group.CompletionCallbackTimeoutSeconds = next)"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Min="1"
                                                             Step="1"
                                                             Immediate="true" />
                                        </div>

                                        <div class="settings-field-block">
                                            <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletionCallbackFinalizationTimeoutSeconds" />
                                            <MudNumericField T="int"
                                                             Value="_callback.CompletionCallbackFinalizationTimeoutSeconds"
                                                             ValueChanged="value => UpdateCallback(value, (group, next) => group.CompletionCallbackFinalizationTimeoutSeconds = next)"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Min="1"
                                                             Step="1"
                                                             Immediate="true" />
                                        </div>
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletionCallbackArguments" />
                                        <MudTextField T="string"
                                                      Value="_callback.CompletionCallbackArguments"
                                                      ValueChanged="value => UpdateCallback(value, (group, next) => group.CompletionCallbackArguments = next)"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletionCallbackWorkingDirectory" />
                                        <MudTextField T="string"
                                                      Value="_callback.CompletionCallbackWorkingDirectory"
                                                      ValueChanged="value => UpdateCallback(value, (group, next) => group.CompletionCallbackWorkingDirectory = next)"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletionCallbackApiBaseUrlOverride" />
                                        <MudTextField T="string"
                                                      Value="_callback.CompletionCallbackApiBaseUrlOverride"
                                                      ValueChanged="value => UpdateCallback(value, (group, next) => group.CompletionCallbackApiBaseUrlOverride = next)"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true" />
                                    </div>

                                    <div class="settings-field-block">
                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.CompletionCallbackApiKeyOverride" />
                                        <MudTextField T="string"
                                                      Value="_callback.CompletionCallbackApiKeyOverride"
                                                      ValueChanged="value => UpdateCallback(value, (group, next) => group.CompletionCallbackApiKeyOverride = next)"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true" />
                                    </div>
                                </div>

                                <p class="dashboard-panel-copy">
                                    Leave the override fields blank for the normal shared TVMaze callback setup. TorrentCore waits for the final visible payload before treating callback finalization as timed out.
                                </p>
                            </div>
                        </OperatorCard>

                        <OperatorCard Class="settings-group-card settings-group-card--wide">
                            <div class="settings-group-shell">
                                @if (IsGroupBlocked(SettingsGroupKey.Categories))
                                {
                                    <button type="button"
                                            class="settings-group-blocker"
                                            @onclick="() => OnBlockedGroupClickedAsync(SettingsGroupKey.Categories)">
                                        <span class="settings-group-blocker-copy">
                                            Resolve @GetGroupTitle(_dirtyGroupKey!.Value) before editing this section.
                                        </span>
                                    </button>
                                }

                                <div class="dashboard-panel-header">
                                    <div>
                                        <h2>Categories</h2>
                                        <p class="dashboard-panel-copy">These definitions route future adds. Editing a category does not move existing torrents.</p>
                                    </div>
                                    <div class="dashboard-inline-actions dashboard-inline-actions--compact settings-group-actions">
                                        <span class="@GetGroupStateClass(SettingsGroupKey.Categories)">@GetGroupStateText(SettingsGroupKey.Categories)</span>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Categories) || IsBusy)"
                                                   OnClick="() => DiscardGroupAsync(SettingsGroupKey.Categories)">
                                            Discard
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@(!IsGroupDirty(SettingsGroupKey.Categories) || IsBusy)"
                                                   OnClick="() => SaveGroupAsync(SettingsGroupKey.Categories)">
                                            Save
                                        </MudButton>
                                    </div>
                                </div>

                                <div class="settings-category-grid">
                                    @foreach (var category in _categories)
                                    {
                                        <div class="settings-category-card" @key="category.Key">
                                            <div class="settings-category-header">
                                                <div>
                                                    <h3>@category.Key</h3>
                                                    <p class="dashboard-panel-copy">Display: @category.DisplayName</p>
                                                </div>
                                                <div class="settings-category-toggles">
                                                    <div class="settings-category-toggle">
                                                        <MudCheckBox T="bool"
                                                                     Value="category.Enabled"
                                                                     ValueChanged="value => UpdateCategory(value, category, (item, next) => item.Enabled = next)"
                                                                     Label="Enabled"
                                                                     Dense="true"
                                                                     Color="Color.Primary" />
                                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.CategoryEnabled" IconOnly="true" />
                                                    </div>
                                                    <div class="settings-category-toggle">
                                                        <MudCheckBox T="bool"
                                                                     Value="category.InvokeCompletionCallback"
                                                                     ValueChanged="value => UpdateCategory(value, category, (item, next) => item.InvokeCompletionCallback = next)"
                                                                     Label="Invoke Callback"
                                                                     Dense="true"
                                                                     Color="Color.Primary" />
                                                        <SettingHelpTrigger Content="@SettingsHelpCatalog.CategoryInvokeCompletionCallback" IconOnly="true" />
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="settings-category-fields">
                                                <div class="settings-field-block settings-category-field settings-category-field--short">
                                                    <SettingHelpTrigger Content="@SettingsHelpCatalog.CategoryDisplayName" />
                                                    <MudTextField T="string"
