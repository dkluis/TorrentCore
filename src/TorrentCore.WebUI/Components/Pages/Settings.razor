                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </OperatorCard>
                    </div>
                </div>
            }
        </StateView>
    </ChildContent>
</OperatorPage>

@code {
    private readonly LifecycleSettingsGroup _lifecycle = new();
    private readonly QueueSettingsGroup _queue = new();
    private readonly EngineThrottleSettingsGroup _engine = new();
    private readonly CallbackSettingsGroup _callback = new();
    private readonly List<EditableCategoryModel> _categories = [];

    private static readonly IReadOnlyList<string> SeedingModes =
    [
        "Unlimited", "StopImmediately", "StopAfterRatio", "StopAfterTime", "StopAfterRatioOrTime",
    ];

    private static readonly IReadOnlyList<string> CleanupModes = ["Never", "AfterCompletedMinutes"];

    private StateViewMode _mode = StateViewMode.Loading;
    private bool _isRefreshing;
    private bool _isResolvingPendingGroup;
    private string? _errorMessage;
    private RuntimeSettingsDto? _runtimeSnapshot;
    private List<TorrentCategoryDto> _categorySnapshots = [];
    private SettingsGroupKey? _dirtyGroupKey;
    private SettingsGroupKey? _savingGroupKey;

    private bool IsBusy => _isRefreshing || _isResolvingPendingGroup || _savingGroupKey is not null;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(showSuccessToast: false);
    }

    private async Task RefreshAsync()
    {
        await ExecuteWithPendingGroupGuardAsync(async () => await LoadAsync(showSuccessToast: true));
    }

    private async Task LoadAsync(bool showSuccessToast)
    {
        _isRefreshing = true;
        _mode = StateViewMode.Loading;
        _errorMessage = null;

        var runtimeTask = Api.GetRuntimeSettingsAsync();
        var categoriesTask = Api.GetCategoriesAsync();
        await Task.WhenAll(runtimeTask, categoriesTask);

        var runtimeResult = await runtimeTask;
        var categoriesResult = await categoriesTask;

        if (!runtimeResult.IsSuccess || runtimeResult.Value is null)
        {
            _errorMessage = runtimeResult.ErrorMessage ?? "Runtime settings request failed.";
            _mode = StateViewMode.Error;
            _isRefreshing = false;
            return;
        }

        if (!categoriesResult.IsSuccess || categoriesResult.Value is null)
        {
            _errorMessage = categoriesResult.ErrorMessage ?? "Category settings request failed.";
            _mode = StateViewMode.Error;
            _isRefreshing = false;
            return;
        }

        ApplyRuntimeSettings(runtimeResult.Value);
        ApplyCategories(categoriesResult.Value);
        _dirtyGroupKey = null;
        _mode = StateViewMode.Ready;
        _isRefreshing = false;

        if (showSuccessToast)
        {
            Feedback.Success("Settings refreshed.");
        }
    }

    private async Task SaveGroupAsync(SettingsGroupKey key)
    {
        if (IsBusy)
        {
            return;
        }

        _savingGroupKey = key;

        try
        {
            switch (key)
            {
                case SettingsGroupKey.Categories:
                    await SaveCategoriesAsync();
                    break;
                default:
                    await SaveRuntimeGroupAsync(key);
                    break;
            }
        }
        finally
        {
            _savingGroupKey = null;
        }
    }

    private async Task SaveRuntimeGroupAsync(SettingsGroupKey key)
    {
        var result = await Api.UpdateRuntimeSettingsAsync(BuildRuntimeSettingsRequest());
        if (!result.IsSuccess || result.Value is null)
        {
            Feedback.Error(result.ErrorMessage ?? $"Unable to save {GetGroupTitle(key)}.");
            return;
        }

        ApplyRuntimeSettings(result.Value);
        _dirtyGroupKey = null;

        Feedback.Success(
            key == SettingsGroupKey.Engine && result.Value.EngineSettingsRequireRestart ?
                "Engine throttles saved. Restart TorrentCore.Service to apply them." :
                $"{GetGroupTitle(key)} saved."
        );
    }

    private async Task SaveCategoriesAsync()
    {
        var updatedCategories = new List<TorrentCategoryDto>(_categories.Count);

        foreach (var category in _categories.OrderBy(item => item.SortOrder)
                                            .ThenBy(item => item.Key, StringComparer.OrdinalIgnoreCase))
        {
            var result = await Api.UpdateCategoryAsync(
                category.Key,
                new UpdateTorrentCategoryRequest
                {
                    DisplayName = category.DisplayName,
                    CallbackLabel = category.CallbackLabel,
                    DownloadRootPath = category.DownloadRootPath,
                    Enabled = category.Enabled,
                    InvokeCompletionCallback = category.InvokeCompletionCallback,
                    SortOrder = category.SortOrder,
                }
            );

            if (!result.IsSuccess || result.Value is null)
            {
                Feedback.Error(result.ErrorMessage ?? "Unable to save categories.");
                return;
            }

            updatedCategories.Add(result.Value);
        }

        ApplyCategories(updatedCategories);
        _dirtyGroupKey = null;
        Feedback.Success("Categories saved.");
    }

    private Task DiscardGroupAsync(SettingsGroupKey key)
    {
        switch (key)
        {
            case SettingsGroupKey.Lifecycle:
                ApplyLifecycleFromSnapshot();
                break;
            case SettingsGroupKey.Queue:
                ApplyQueueFromSnapshot();
                break;
            case SettingsGroupKey.Engine:
                ApplyEngineFromSnapshot();
                break;
            case SettingsGroupKey.Callback:
                ApplyCallbackFromSnapshot();
                break;
            case SettingsGroupKey.Categories:
                ApplyCategories(_categorySnapshots);
                break;
        }

        if (_dirtyGroupKey == key)
        {
            _dirtyGroupKey = null;
        }

        Feedback.Info($"{GetGroupTitle(key)} changes discarded.");
        return Task.CompletedTask;
    }

    private async Task OnBlockedGroupClickedAsync(SettingsGroupKey targetGroupKey)
    {
        if (!IsGroupBlocked(targetGroupKey))
        {
            return;
        }

        await ResolvePendingGroupAsync();
    }

    private async Task ExecuteWithPendingGroupGuardAsync(Func<Task> action)
    {
        if (!await ResolvePendingGroupAsync())
        {
            return;
        }

        await action();
    }

    private async Task<bool> ResolvePendingGroupAsync()
    {
        if (_dirtyGroupKey is null || _isResolvingPendingGroup)
        {
            return _dirtyGroupKey is null;
        }

        _isResolvingPendingGroup = true;

        try
        {
            var dirtyGroup = _dirtyGroupKey.Value;
            var dialog = await DialogService.ShowAsync<PendingSettingsGroupDialog>(
                "Unsaved Changes",
                new DialogParameters
                {
                    [nameof(PendingSettingsGroupDialog.GroupName)] = GetGroupTitle(dirtyGroup),
                },
                new DialogOptions
                {
                    CloseButton = true,
                    CloseOnEscapeKey = true,
                    BackdropClick = false,
                    FullWidth = true,
                    MaxWidth = MaxWidth.Small,
                }
            );

            var result = await dialog.Result;
            if (result is null || result.Canceled)
            {
                return false;
            }

            var action = result.Data?.ToString();
            if (string.Equals(action, "save", StringComparison.OrdinalIgnoreCase))
            {
                await SaveGroupAsync(dirtyGroup);
                return _dirtyGroupKey is null;
            }

            if (string.Equals(action, "discard", StringComparison.OrdinalIgnoreCase))
            {
                await DiscardGroupAsync(dirtyGroup);
                return true;
            }

            return false;
        }
        finally
        {
            _isResolvingPendingGroup = false;
        }
    }

    private void ApplyRuntimeSettings(RuntimeSettingsDto settings)
    {
        _runtimeSnapshot = settings;
        ApplyLifecycleFromSnapshot();
        ApplyQueueFromSnapshot();
        ApplyEngineFromSnapshot();
        ApplyCallbackFromSnapshot();
    }

    private void ApplyCategories(IReadOnlyList<TorrentCategoryDto> categories)
    {
        _categorySnapshots = categories
            .OrderBy(item => item.SortOrder)
            .ThenBy(item => item.Key, StringComparer.OrdinalIgnoreCase)
            .ToList();

        _categories.Clear();
        _categories.AddRange(
            _categorySnapshots.Select(
                category => new EditableCategoryModel
                {
                    Key = category.Key,
                    DisplayName = category.DisplayName,
                    CallbackLabel = category.CallbackLabel,
                    DownloadRootPath = category.DownloadRootPath,
                    Enabled = category.Enabled,
                    InvokeCompletionCallback = category.InvokeCompletionCallback,
                    SortOrder = category.SortOrder,
                }
            )
        );
    }

    private void ApplyLifecycleFromSnapshot()
    {
        if (_runtimeSnapshot is null)
        {
            return;
        }

        _lifecycle.SeedingStopMode = _runtimeSnapshot.SeedingStopMode;
        _lifecycle.SeedingStopRatio = _runtimeSnapshot.SeedingStopRatio;
        _lifecycle.SeedingStopMinutes = _runtimeSnapshot.SeedingStopMinutes;
        _lifecycle.CompletedTorrentCleanupMode = _runtimeSnapshot.CompletedTorrentCleanupMode;
        _lifecycle.CompletedTorrentCleanupMinutes = _runtimeSnapshot.CompletedTorrentCleanupMinutes;
        _lifecycle.DeleteLogsForCompletedTorrents = _runtimeSnapshot.DeleteLogsForCompletedTorrents;
    }

    private void ApplyQueueFromSnapshot()
    {
        if (_runtimeSnapshot is null)
        {
            return;
        }

        _queue.MaxActiveMetadataResolutions = _runtimeSnapshot.MaxActiveMetadataResolutions;
        _queue.MaxActiveDownloads = _runtimeSnapshot.MaxActiveDownloads;
        _queue.MetadataRefreshStaleSeconds = _runtimeSnapshot.MetadataRefreshStaleSeconds;
        _queue.MetadataRefreshRestartDelaySeconds = _runtimeSnapshot.MetadataRefreshRestartDelaySeconds;
        _queue.EngineConnectionFailureLogBurstLimit = _runtimeSnapshot.EngineConnectionFailureLogBurstLimit;
        _queue.EngineConnectionFailureLogWindowSeconds = _runtimeSnapshot.EngineConnectionFailureLogWindowSeconds;
    }

    private void ApplyEngineFromSnapshot()
    {
        if (_runtimeSnapshot is null)
        {
            return;
        }

        _engine.EngineMaximumConnections = _runtimeSnapshot.EngineMaximumConnections;
        _engine.EngineMaximumHalfOpenConnections = _runtimeSnapshot.EngineMaximumHalfOpenConnections;
        _engine.EngineMaximumDownloadRateBytesPerSecond = _runtimeSnapshot.EngineMaximumDownloadRateBytesPerSecond;
        _engine.EngineMaximumUploadRateBytesPerSecond = _runtimeSnapshot.EngineMaximumUploadRateBytesPerSecond;
    }

    private void ApplyCallbackFromSnapshot()
    {
        if (_runtimeSnapshot is null)
        {
            return;
        }

        _callback.CompletionCallbackEnabled = _runtimeSnapshot.CompletionCallbackEnabled;
        _callback.CompletionCallbackCommandPath = _runtimeSnapshot.CompletionCallbackCommandPath ?? string.Empty;
        _callback.CompletionCallbackArguments = _runtimeSnapshot.CompletionCallbackArguments ?? string.Empty;
        _callback.CompletionCallbackWorkingDirectory = _runtimeSnapshot.CompletionCallbackWorkingDirectory ?? string.Empty;
        _callback.CompletionCallbackTimeoutSeconds = _runtimeSnapshot.CompletionCallbackTimeoutSeconds;
        _callback.CompletionCallbackFinalizationTimeoutSeconds = _runtimeSnapshot.CompletionCallbackFinalizationTimeoutSeconds;
        _callback.CompletionCallbackApiBaseUrlOverride = _runtimeSnapshot.CompletionCallbackApiBaseUrlOverride ?? string.Empty;
        _callback.CompletionCallbackApiKeyOverride = _runtimeSnapshot.CompletionCallbackApiKeyOverride ?? string.Empty;
    }

    private UpdateRuntimeSettingsRequest BuildRuntimeSettingsRequest()
    {
        return new UpdateRuntimeSettingsRequest
        {
            SeedingStopMode = _lifecycle.SeedingStopMode,
            SeedingStopRatio = _lifecycle.SeedingStopRatio,
            SeedingStopMinutes = _lifecycle.SeedingStopMinutes,
            CompletedTorrentCleanupMode = _lifecycle.CompletedTorrentCleanupMode,
            CompletedTorrentCleanupMinutes = _lifecycle.CompletedTorrentCleanupMinutes,
            DeleteLogsForCompletedTorrents = _lifecycle.DeleteLogsForCompletedTorrents,
            EngineConnectionFailureLogBurstLimit = _queue.EngineConnectionFailureLogBurstLimit,
            EngineConnectionFailureLogWindowSeconds = _queue.EngineConnectionFailureLogWindowSeconds,
            EngineMaximumConnections = _engine.EngineMaximumConnections,
            EngineMaximumHalfOpenConnections = _engine.EngineMaximumHalfOpenConnections,
            EngineMaximumDownloadRateBytesPerSecond = _engine.EngineMaximumDownloadRateBytesPerSecond,
            EngineMaximumUploadRateBytesPerSecond = _engine.EngineMaximumUploadRateBytesPerSecond,
            MaxActiveMetadataResolutions = _queue.MaxActiveMetadataResolutions,
            MaxActiveDownloads = _queue.MaxActiveDownloads,
            MetadataRefreshStaleSeconds = _queue.MetadataRefreshStaleSeconds,
            MetadataRefreshRestartDelaySeconds = _queue.MetadataRefreshRestartDelaySeconds,
            CompletionCallbackEnabled = _callback.CompletionCallbackEnabled,
            CompletionCallbackCommandPath = _callback.CompletionCallbackCommandPath,
            CompletionCallbackArguments = _callback.CompletionCallbackArguments,
            CompletionCallbackWorkingDirectory = _callback.CompletionCallbackWorkingDirectory,
            CompletionCallbackTimeoutSeconds = _callback.CompletionCallbackTimeoutSeconds,
            CompletionCallbackFinalizationTimeoutSeconds = _callback.CompletionCallbackFinalizationTimeoutSeconds,
            CompletionCallbackApiBaseUrlOverride = _callback.CompletionCallbackApiBaseUrlOverride,
            CompletionCallbackApiKeyOverride = _callback.CompletionCallbackApiKeyOverride,
        };
    }

    private Task UpdateLifecycle<T>(T value, Action<LifecycleSettingsGroup, T> assign)
    {
        assign(_lifecycle, value);
        UpdateDirtyGroup(SettingsGroupKey.Lifecycle);
        return Task.CompletedTask;
    }

    private Task UpdateQueue<T>(T value, Action<QueueSettingsGroup, T> assign)
    {
        assign(_queue, value);
        UpdateDirtyGroup(SettingsGroupKey.Queue);
        return Task.CompletedTask;
    }

    private Task UpdateEngine<T>(T value, Action<EngineThrottleSettingsGroup, T> assign)
    {
        assign(_engine, value);
        UpdateDirtyGroup(SettingsGroupKey.Engine);
        return Task.CompletedTask;
    }

    private Task UpdateCallback<T>(T value, Action<CallbackSettingsGroup, T> assign)
    {
        assign(_callback, value);
        UpdateDirtyGroup(SettingsGroupKey.Callback);
        return Task.CompletedTask;
    }

    private Task UpdateCategory<T>(T value, EditableCategoryModel category, Action<EditableCategoryModel, T> assign)
    {
        assign(category, value);
        UpdateDirtyGroup(SettingsGroupKey.Categories);
        return Task.CompletedTask;
    }

    private void UpdateDirtyGroup(SettingsGroupKey key)
    {
        if (IsGroupDirty(key))
        {
            _dirtyGroupKey = key;
            return;
        }

        if (_dirtyGroupKey == key)
        {
            _dirtyGroupKey = null;
        }
    }

    private bool IsGroupDirty(SettingsGroupKey key)
    {
        return key switch
        {
            SettingsGroupKey.Lifecycle => IsLifecycleDirty(),
            SettingsGroupKey.Queue => IsQueueDirty(),
            SettingsGroupKey.Engine => IsEngineDirty(),
            SettingsGroupKey.Callback => IsCallbackDirty(),
            SettingsGroupKey.Categories => IsCategoriesDirty(),
            _ => false,
        };
    }

    private bool IsGroupBlocked(SettingsGroupKey key)
    {
        return _dirtyGroupKey is not null && _dirtyGroupKey != key;
    }

    private bool IsLifecycleDirty()
    {
        return _runtimeSnapshot is not null &&
               (_lifecycle.SeedingStopMode != _runtimeSnapshot.SeedingStopMode ||
                _lifecycle.SeedingStopRatio != _runtimeSnapshot.SeedingStopRatio ||
                _lifecycle.SeedingStopMinutes != _runtimeSnapshot.SeedingStopMinutes ||
                _lifecycle.CompletedTorrentCleanupMode != _runtimeSnapshot.CompletedTorrentCleanupMode ||
                _lifecycle.CompletedTorrentCleanupMinutes != _runtimeSnapshot.CompletedTorrentCleanupMinutes ||
                _lifecycle.DeleteLogsForCompletedTorrents != _runtimeSnapshot.DeleteLogsForCompletedTorrents);
    }

    private bool IsQueueDirty()
    {
        return _runtimeSnapshot is not null &&
               (_queue.MaxActiveMetadataResolutions != _runtimeSnapshot.MaxActiveMetadataResolutions ||
                _queue.MaxActiveDownloads != _runtimeSnapshot.MaxActiveDownloads ||
                _queue.MetadataRefreshStaleSeconds != _runtimeSnapshot.MetadataRefreshStaleSeconds ||
                _queue.MetadataRefreshRestartDelaySeconds != _runtimeSnapshot.MetadataRefreshRestartDelaySeconds ||
                _queue.EngineConnectionFailureLogBurstLimit != _runtimeSnapshot.EngineConnectionFailureLogBurstLimit ||
                _queue.EngineConnectionFailureLogWindowSeconds != _runtimeSnapshot.EngineConnectionFailureLogWindowSeconds);
    }

    private bool IsEngineDirty()
    {
        return _runtimeSnapshot is not null &&
               (_engine.EngineMaximumConnections != _runtimeSnapshot.EngineMaximumConnections ||
                _engine.EngineMaximumHalfOpenConnections != _runtimeSnapshot.EngineMaximumHalfOpenConnections ||
                _engine.EngineMaximumDownloadRateBytesPerSecond != _runtimeSnapshot.EngineMaximumDownloadRateBytesPerSecond ||
                _engine.EngineMaximumUploadRateBytesPerSecond != _runtimeSnapshot.EngineMaximumUploadRateBytesPerSecond);
    }

    private bool IsCallbackDirty()
    {
        return _runtimeSnapshot is not null &&
               (_callback.CompletionCallbackEnabled != _runtimeSnapshot.CompletionCallbackEnabled ||
                _callback.CompletionCallbackCommandPath != (_runtimeSnapshot.CompletionCallbackCommandPath ?? string.Empty) ||
                _callback.CompletionCallbackArguments != (_runtimeSnapshot.CompletionCallbackArguments ?? string.Empty) ||
                _callback.CompletionCallbackWorkingDirectory != (_runtimeSnapshot.CompletionCallbackWorkingDirectory ?? string.Empty) ||
                _callback.CompletionCallbackTimeoutSeconds != _runtimeSnapshot.CompletionCallbackTimeoutSeconds ||
                _callback.CompletionCallbackFinalizationTimeoutSeconds != _runtimeSnapshot.CompletionCallbackFinalizationTimeoutSeconds ||
                _callback.CompletionCallbackApiBaseUrlOverride != (_runtimeSnapshot.CompletionCallbackApiBaseUrlOverride ?? string.Empty) ||
                _callback.CompletionCallbackApiKeyOverride != (_runtimeSnapshot.CompletionCallbackApiKeyOverride ?? string.Empty));
    }

    private bool IsCategoriesDirty()
    {
        if (_categories.Count != _categorySnapshots.Count)
        {
            return true;
        }

        var snapshotLookup = _categorySnapshots.ToDictionary(item => item.Key, StringComparer.OrdinalIgnoreCase);
        foreach (var category in _categories)
        {
            if (!snapshotLookup.TryGetValue(category.Key, out var snapshot))
            {
                return true;
            }

            if (category.DisplayName != snapshot.DisplayName ||
                category.CallbackLabel != snapshot.CallbackLabel ||
                category.DownloadRootPath != snapshot.DownloadRootPath ||
                category.Enabled != snapshot.Enabled ||
                category.InvokeCompletionCallback != snapshot.InvokeCompletionCallback ||
                category.SortOrder != snapshot.SortOrder)
            {
                return true;
            }
        }

        return false;
    }

    private string BuildStatusLine()
    {
        if (_dirtyGroupKey is null)
        {
            return "Each group saves independently. Once you start editing a group, save or discard it before moving to another section.";
        }

        return $"{GetGroupTitle(_dirtyGroupKey.Value)} has unsaved changes. Save or discard before editing another section.";
    }

    private string GetGroupStateText(SettingsGroupKey key)
    {
        if (_savingGroupKey == key)
        {
            return "Saving";
        }

        return IsGroupDirty(key) ? "Edited" : "Saved";
    }

    private string GetGroupStateClass(SettingsGroupKey key)
    {
        return IsGroupDirty(key) ? "settings-group-state settings-group-state--dirty" : "settings-group-state";
    }

    private static string GetGroupTitle(SettingsGroupKey key)
    {
        return key switch
        {
            SettingsGroupKey.Lifecycle => "Lifecycle & Cleanup",
            SettingsGroupKey.Queue => "Queue & Recovery",
            SettingsGroupKey.Engine => "Engine Throttles",
            SettingsGroupKey.Callback => "Completion Callback",
            SettingsGroupKey.Categories => "Categories",
            _ => "Settings",
        };
    }

    private static string FormatRate(int bytesPerSecond)
    {
        return bytesPerSecond <= 0 ? "Unlimited" : $"{bytesPerSecond / 1_000_000.0:0.00} MB/s";
    }

    private enum SettingsGroupKey
    {
        Lifecycle,
        Queue,
        Engine,
        Callback,
        Categories,
    }

    private sealed class LifecycleSettingsGroup
    {
        public string SeedingStopMode { get; set; } = "Unlimited";
        public double SeedingStopRatio { get; set; } = 1.0;
        public int SeedingStopMinutes { get; set; } = 60;
        public string CompletedTorrentCleanupMode { get; set; } = "Never";
        public int CompletedTorrentCleanupMinutes { get; set; } = 60;
        public bool DeleteLogsForCompletedTorrents { get; set; }
    }

    private sealed class QueueSettingsGroup
    {
        public int MaxActiveMetadataResolutions { get; set; } = 4;
        public int MaxActiveDownloads { get; set; } = 4;
        public int MetadataRefreshStaleSeconds { get; set; } = 90;
        public int MetadataRefreshRestartDelaySeconds { get; set; } = 30;
        public int EngineConnectionFailureLogBurstLimit { get; set; } = 5;
        public int EngineConnectionFailureLogWindowSeconds { get; set; } = 60;
    }

    private sealed class EngineThrottleSettingsGroup
    {
        public int EngineMaximumConnections { get; set; } = 150;
        public int EngineMaximumHalfOpenConnections { get; set; } = 8;
        public int EngineMaximumDownloadRateBytesPerSecond { get; set; }
        public int EngineMaximumUploadRateBytesPerSecond { get; set; }
    }

    private sealed class CallbackSettingsGroup
    {
        public bool CompletionCallbackEnabled { get; set; }
        public string CompletionCallbackCommandPath { get; set; } = string.Empty;
        public string CompletionCallbackArguments { get; set; } = string.Empty;
        public string CompletionCallbackWorkingDirectory { get; set; } = string.Empty;
        public int CompletionCallbackTimeoutSeconds { get; set; } = 30;
        public int CompletionCallbackFinalizationTimeoutSeconds { get; set; } = 120;
        public string CompletionCallbackApiBaseUrlOverride { get; set; } = string.Empty;
        public string CompletionCallbackApiKeyOverride { get; set; } = string.Empty;
    }

    private sealed class EditableCategoryModel
    {
        public required string Key { get; init; }
        public string DisplayName { get; set; } = string.Empty;
        public string CallbackLabel { get; set; } = string.Empty;
        public string DownloadRootPath { get; set; } = string.Empty;
        public bool Enabled { get; set; }
        public bool InvokeCompletionCallback { get; set; }
        public int SortOrder { get; set; }
    }
}
