                                                <div class="settings-field-block settings-category-field settings-category-field--path">
                                                    <SettingHelpTrigger Content="@SettingsHelpCatalog.CategoryDownloadRootPath" />
                                                    <MudTextField T="string"
                                                                  Value="category.DownloadRootPath"
                                                                  ValueChanged="value => UpdateCategory(value, category, (item, next) => item.DownloadRootPath = next)"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true" />
