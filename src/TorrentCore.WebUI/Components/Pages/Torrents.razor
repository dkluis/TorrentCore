@page "/torrents"
@implements IAsyncDisposable
@inject ITorrentCoreApiAdapter Api
@inject IOperatorFeedbackService Feedback
@inject IPageStateStore PageStateStore

<PageTitle>Torrents</PageTitle>

<OperatorPage Kicker="Workflow"
              Title="Torrents"
              Summary="Single-grid torrent workflow with selected detail/actions, TVMaze-style panel composition, and periodic refresh."
              Class="torrents-page"
              StatusLine="Auto refresh runs every 5 seconds. Select a row to manage one torrent from the detail panel. Sort from grid headers.">
    <HeaderActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   Disabled="_isRefreshing || _isActingOnSelected"
                   OnClick="RefreshAsync">
            Refresh
        </MudButton>
    </HeaderActions>

    <ChildContent>
        <StateView Mode="@_mode"
                   Title="Torrent list unavailable"
                   Message="@_errorMessage"
                   ActionText="Retry"
                   OnAction="RefreshAsync">
            <div class="dashboard-tab-content torrents-tab-content">
                <div class="torrents-grid">
                    <OperatorCard Class="section-card torrents-panel torrents-panel--filters">
                        <div class="dashboard-panel-header">
                            <div>
                                <h2>Filters</h2>
                                <p class="dashboard-panel-copy">Filtering and sort are local. Select a row to open details and actions below.</p>
                            </div>
                            <div class="dashboard-inline-actions dashboard-inline-actions--compact">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="_isRefreshing || _isActingOnSelected"
                                           OnClick="RefreshAsync">
                                    Refresh
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           Disabled="_isRefreshing || _isActingOnSelected"
                                           OnClick="ClearFiltersAsync">
                                    Clear
                                </MudButton>
                            </div>
                        </div>

                        <div class="operations-filters">
                            <MudTextField T="string"
                                          Label="Name"
                                          Value="_state.SearchText"
                                          ValueChanged="OnSearchChanged"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true" />

                            <MudSelect T="string"
                                       Label="State"
                                       Value="_state.PrimaryFilter"
                                       ValueChanged="OnStateFilterChanged"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Dense="true">
                                <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                                @foreach (var torrentState in Enum.GetValues<TorrentState>())
                                {
                                    <MudSelectItem T="string" Value="@torrentState.ToString()">@torrentState</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="string"
                                       Label="Category"
                                       Value="_state.SecondaryFilter"
                                       ValueChanged="OnCategoryFilterChanged"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Dense="true">
                                <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                                <MudSelectItem T="string" Value="@UncategorizedFilterValue">Uncategorized</MudSelectItem>
                                @foreach (var category in CategoryFilterOptions)
                                {
                                    <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                                }
                            </MudSelect>

                            <MudCheckBox T="bool"
                                         Dense="true"
                                         Color="Color.Primary"
                                         Label="Auto Refresh (5s)"
                                         Value="_autoRefreshEnabled"
                                         ValueChanged="OnAutoRefreshChanged" />
                        </div>
                    </OperatorCard>

                    <OperatorCard Class="section-card torrents-panel torrents-panel--table">
                        <div class="dashboard-panel-header">
                            <div>
                                <h2>Current Torrents</h2>
                                <p class="dashboard-panel-copy">@FilteredTorrents.Count result(s)</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_actionMessage))
                        {
                            <p class="@GetActionMessageClass()">@_actionMessage</p>
                        }

                        <div class="operations-table-frame torrents-table-frame">
                            <MudTable T="TorrentSummaryDto"
                                      Items="FilteredTorrents"
                                      Dense="true"
                                      Hover="true"
                                      Bordered="true"
                                      Striped="true"
                                      FixedHeader="true"
                                      Loading="_isRefreshing"
                                      Breakpoint="Breakpoint.Md"
                                      Height="100%"
                                      RowsPerPage="@_state.PageSize"
                                      RowsPerPageChanged="OnRowsPerPageChanged"
                                      OnRowClick="OnTorrentRowClickAsync"
                                      RowClassFunc="GetTorrentRowClass"
                                      Class="operations-table torrents-table"
                                      Elevation="0">
                                <HeaderContent>
                                    <MudTh>
                                        <MudTableSortLabel T="TorrentSummaryDto" SortBy="@(torrent => torrent.Name)">Name</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="TorrentSummaryDto" SortBy="@(torrent => torrent.CategoryKey ?? string.Empty)">Category</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="TorrentSummaryDto" SortBy="@(torrent => torrent.State.ToString())">State</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="TorrentSummaryDto" SortBy="@(torrent => torrent.ProgressPercent)">Progress</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="TorrentSummaryDto" SortBy="@(torrent => torrent.DownloadRateBytesPerSecond)">Down</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="TorrentSummaryDto" SortBy="@(torrent => torrent.UploadRateBytesPerSecond)">Up</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="TorrentSummaryDto" SortBy="@(torrent => torrent.ConnectedPeerCount)">Peers</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel T="TorrentSummaryDto" SortBy="@(torrent => (int?)torrent.WaitReason ?? -1)">Wait</MudTableSortLabel>
                                    </MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Name" Class="operations-table-wrap">@context.Name</MudTd>
                                    <MudTd DataLabel="Category">@FormatCategory(context.CategoryKey)</MudTd>
                                    <MudTd DataLabel="State">@context.State</MudTd>
                                    <MudTd DataLabel="Progress">@context.ProgressPercent.ToString("0.0")%</MudTd>
                                    <MudTd DataLabel="Down">@FormatRate(context.DownloadRateBytesPerSecond)</MudTd>
                                    <MudTd DataLabel="Up">@FormatRate(context.UploadRateBytesPerSecond)</MudTd>
                                    <MudTd DataLabel="Peers">@context.ConnectedPeerCount</MudTd>
                                    <MudTd DataLabel="Wait" Class="operations-table-wrap">@FormatWaitReason(context.WaitReason, context.QueuePosition)</MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudText Typo="Typo.body2">No torrents match the current filters.</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 250 }"
                                                   RowsPerPageString="Rows" />
                                </PagerContent>
                            </MudTable>
                        </div>
                    </OperatorCard>

                    <OperatorCard Class="section-card torrents-panel torrents-panel--detail">
                        <div class="dashboard-panel-header">
                            <div>
                                <h2>Selected Torrent</h2>
                                <p class="dashboard-panel-copy">@BuildSelectionSummary()</p>
                            </div>
                            @if (CanShowSelectedActions)
                            {
                                <div class="torrents-actions">
                                    @if (_selectedTorrentDetail!.CanPause)
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@DisableSelectedActions"
                                                   OnClick="PauseSelectedAsync">
                                            Pause
                                        </MudButton>
                                    }
                                    @if (_selectedTorrentDetail.CanResume)
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@DisableSelectedActions"
                                                   OnClick="ResumeSelectedAsync">
                                            Resume
                                        </MudButton>
                                    }
                                    @if (_selectedTorrentDetail.CanRefreshMetadata)
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@DisableSelectedActions"
                                                   OnClick="RefreshMetadataSelectedAsync">
                                            Refresh Metadata
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@DisableSelectedActions"
                                                   OnClick="ResetMetadataSelectedAsync">
                                            Reset Metadata
                                        </MudButton>
                                    }
                                    @if (_selectedTorrentDetail.CanRetryCompletionCallback)
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@DisableSelectedActions"
                                                   OnClick="RetryCallbackSelectedAsync">
                                            Retry Callback
                                        </MudButton>
                                    }
                                    @if (_selectedTorrentDetail.CanRemove)
                                    {
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   Disabled="@DisableSelectedActions"
                                                   OnClick="RemoveSelectedAsync">
                                            Remove
                                        </MudButton>
                                        @if (CanDeleteData(_selectedTorrentDetail))
                                        {
                                            <MudButton Variant="Variant.Filled"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       Disabled="@DisableSelectedActions"
                                                       OnClick="DeleteSelectedDataAsync">
                                                Delete Data
                                            </MudButton>
                                        }
                                    }
                                </div>
                            }
                        </div>

                        @if (_isLoadingSelectedDetail)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }

                        @if (!string.IsNullOrWhiteSpace(_selectedDetailErrorMessage))
                        {
                            <div class="dashboard-callout">
                                <p class="dashboard-callout-title">Selected torrent unavailable</p>
                                <p class="dashboard-callout-copy">@_selectedDetailErrorMessage</p>
                            </div>
                        }
                        else if (_selectedTorrentDetail is null)
                        {
                            <div class="dashboard-callout">
                                <p class="dashboard-callout-title">No torrent selected</p>
                                <p class="dashboard-callout-copy">Click a row in the grid to view full details and run actions.</p>
                            </div>
                        }
                        else
                        {
                            <div class="dashboard-detail-grid">
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Name</p>
                                    <p class="dashboard-detail-value">@_selectedTorrentDetail.Name</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">State</p>
                                    <p class="dashboard-detail-value">@_selectedTorrentDetail.State</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Category</p>
                                    <p class="dashboard-detail-value">@FormatCategory(_selectedTorrentDetail.CategoryKey)</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Progress</p>
                                    <p class="dashboard-detail-value">@_selectedTorrentDetail.ProgressPercent.ToString("0.0")%</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Download</p>
                                    <p class="dashboard-detail-value">@FormatRate(_selectedTorrentDetail.DownloadRateBytesPerSecond)</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Upload</p>
                                    <p class="dashboard-detail-value">@FormatRate(_selectedTorrentDetail.UploadRateBytesPerSecond)</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Peers</p>
                                    <p class="dashboard-detail-value">@_selectedTorrentDetail.ConnectedPeerCount</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Trackers</p>
                                    <p class="dashboard-detail-value">@_selectedTorrentDetail.TrackerCount</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Wait</p>
                                    <p class="dashboard-detail-value">@FormatWaitReason(_selectedTorrentDetail.WaitReason, _selectedTorrentDetail.QueuePosition)</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Info Hash</p>
                                    <p class="dashboard-detail-value">@(_selectedTorrentDetail.InfoHash ?? "N/A")</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Added</p>
                                    <p class="dashboard-detail-value">@FormatTimestamp(_selectedTorrentDetail.AddedAtUtc)</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Completed</p>
                                    <p class="dashboard-detail-value">@FormatTimestamp(_selectedTorrentDetail.CompletedAtUtc)</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Last Activity</p>
                                    <p class="dashboard-detail-value">@FormatTimestamp(_selectedTorrentDetail.LastActivityAtUtc)</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Downloaded</p>
                                    <p class="dashboard-detail-value">@FormatSize(_selectedTorrentDetail.DownloadedBytes)</p>
                                </div>
                                <div class="dashboard-detail-item">
                                    <p class="dashboard-detail-label">Total Size</p>
                                    <p class="dashboard-detail-value">@FormatNullableSize(_selectedTorrentDetail.TotalBytes)</p>
                                </div>
                                <div class="dashboard-detail-item dashboard-detail-item--span-2">
                                    <p class="dashboard-detail-label">Save Path</p>
                                    <p class="dashboard-detail-value dashboard-detail-value--wrap">@_selectedTorrentDetail.SavePath</p>
                                </div>
                                <div class="dashboard-detail-item dashboard-detail-item--span-2">
                                    <p class="dashboard-detail-label">Magnet</p>
                                    <p class="dashboard-detail-value dashboard-detail-value--wrap">@_selectedTorrentDetail.MagnetUri</p>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(_selectedTorrentDetail.CompletionCallbackState))
                                {
                                    <div class="dashboard-detail-item">
                                        <p class="dashboard-detail-label">Callback State</p>
                                        <p class="dashboard-detail-value">@_selectedTorrentDetail.CompletionCallbackState</p>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_selectedTorrentDetail.CompletionCallbackPendingReason))
                                {
                                    <div class="dashboard-detail-item dashboard-detail-item--span-2">
                                        <p class="dashboard-detail-label">Callback Pending Reason</p>
                                        <p class="dashboard-detail-value">@_selectedTorrentDetail.CompletionCallbackPendingReason</p>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_selectedTorrentDetail.CompletionCallbackLastError))
                                {
                                    <div class="dashboard-detail-item dashboard-detail-item--span-2">
                                        <p class="dashboard-detail-label">Callback Last Error</p>
                                        <p class="dashboard-detail-value">@_selectedTorrentDetail.CompletionCallbackLastError</p>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_selectedTorrentDetail.ErrorMessage))
                                {
                                    <div class="dashboard-detail-item dashboard-detail-item--span-2">
                                        <p class="dashboard-detail-label">Error</p>
                                        <p class="dashboard-detail-value">@_selectedTorrentDetail.ErrorMessage</p>
                                    </div>
                                }
                            </div>
                        }
                    </OperatorCard>
                </div>
            </div>
        </StateView>
    </ChildContent>
</OperatorPage>

@code {
    private const string StateKey = "torrents:list";
    private const int AutoRefreshSeconds = 5;
    private const string UncategorizedFilterValue = "__uncategorized";

    private readonly List<TorrentSummaryDto> _allTorrents = [];

    private StandardListPageState _state = new()
    {
        PageSize = 25,
    };

    private StateViewMode _mode = StateViewMode.Loading;
    private CancellationTokenSource? _refreshLoopCts;
    private Task? _refreshLoopTask;
    private bool _autoRefreshEnabled = true;
    private bool _isActingOnSelected;
    private bool _isDisposed;
    private bool _isLoadingSelectedDetail;
    private bool _isRefreshing;
    private Guid? _selectedTorrentId;
    private string? _actionMessage;
    private bool _actionIsError;
    private string? _errorMessage;
    private string? _selectedDetailErrorMessage;
    private TorrentDetailDto? _selectedTorrentDetail;

    private IReadOnlyList<TorrentSummaryDto> FilteredTorrents
    {
        get
        {
            IEnumerable<TorrentSummaryDto> query = _allTorrents;

            if (!string.IsNullOrWhiteSpace(_state.SearchText))
            {
                query = query.Where(torrent => torrent.Name.Contains(_state.SearchText, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(_state.PrimaryFilter))
            {
                query = query.Where(
                    torrent => string.Equals(
                        torrent.State.ToString(),
                        _state.PrimaryFilter,
                        StringComparison.OrdinalIgnoreCase
                    )
                );
            }

            if (!string.IsNullOrWhiteSpace(_state.SecondaryFilter))
            {
                query = string.Equals(_state.SecondaryFilter, UncategorizedFilterValue, StringComparison.Ordinal)
                    ? query.Where(torrent => string.IsNullOrWhiteSpace(torrent.CategoryKey))
                    : query.Where(
                        torrent => string.Equals(
                            torrent.CategoryKey,
                            _state.SecondaryFilter,
                            StringComparison.OrdinalIgnoreCase
                        )
                    );
            }

            return query
                .OrderByDescending(torrent => torrent.AddedAtUtc)
                .ThenBy(torrent => torrent.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
    }

    private IReadOnlyList<string> CategoryFilterOptions =>
        _allTorrents
            .Select(torrent => torrent.CategoryKey)
            .Where(static category => !string.IsNullOrWhiteSpace(category))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(static category => category, StringComparer.OrdinalIgnoreCase)
            .Cast<string>()
            .ToArray();

    private bool CanShowSelectedActions => _selectedTorrentDetail is not null;

    private bool DisableSelectedActions =>
        _isRefreshing || _isActingOnSelected || _isLoadingSelectedDetail || _selectedTorrentDetail is null;

    protected override async Task OnInitializedAsync()
    {
        _state = PageStateStore.GetOrCreate(
            StateKey,
            () => new StandardListPageState
            {
                PageSize = 25,
            }
        );

        if (_state.PageSize <= 0)
        {
            _state.PageSize = 25;
        }

        await LoadAsync(showSuccessToast: false, showLoadingState: true, fromAutoRefresh: false);
        _refreshLoopCts = new CancellationTokenSource();
        _refreshLoopTask = RunRefreshLoopAsync(_refreshLoopCts.Token);
    }

    private async Task RefreshAsync()
    {
        await LoadAsync(showSuccessToast: true, showLoadingState: false, fromAutoRefresh: false);
    }

    private async Task LoadAsync(bool showSuccessToast, bool showLoadingState, bool fromAutoRefresh)
    {
        if (_isDisposed || _isRefreshing)
        {
            return;
        }

        _isRefreshing = true;

        if (showLoadingState)
        {
            _mode = StateViewMode.Loading;
        }

        _errorMessage = null;

        var torrentsResult = await Api.GetTorrentsAsync();
        if (!torrentsResult.IsSuccess)
        {
            var errorMessage = torrentsResult.ErrorMessage ?? "Torrent list request failed.";
            _errorMessage = errorMessage;
            _mode = _allTorrents.Count == 0 ? StateViewMode.Error : StateViewMode.Ready;
            _isRefreshing = false;

            if (!fromAutoRefresh)
            {
                _actionMessage = errorMessage;
                _actionIsError = true;
                Feedback.Error(errorMessage);
            }

            return;
        }

        _allTorrents.Clear();
        if (torrentsResult.Value is not null)
        {
            _allTorrents.AddRange(torrentsResult.Value);
        }

        if (_selectedTorrentId is not null && _allTorrents.All(torrent => torrent.TorrentId != _selectedTorrentId.Value))
        {
            _selectedTorrentId = null;
            _selectedTorrentDetail = null;
            _selectedDetailErrorMessage = null;
        }
        else if (_selectedTorrentId is not null)
        {
            await LoadSelectedTorrentDetailAsync(_selectedTorrentId.Value, fromRefresh: true);
        }

        _mode = StateViewMode.Ready;
        _isRefreshing = false;

        if (showSuccessToast)
        {
            Feedback.Success("Torrent list refreshed.");
        }
    }

    private async Task OnTorrentRowClickAsync(TableRowClickEventArgs<TorrentSummaryDto> args)
    {
        if (args.Item is null)
        {
            return;
        }

        _selectedTorrentId = args.Item.TorrentId;
        await LoadSelectedTorrentDetailAsync(args.Item.TorrentId, fromRefresh: false);
    }

    private async Task LoadSelectedTorrentDetailAsync(Guid torrentId, bool fromRefresh)
    {
        _isLoadingSelectedDetail = true;
        _selectedDetailErrorMessage = null;

        var detailResult = await Api.GetTorrentAsync(torrentId);
        if (!detailResult.IsSuccess)
        {
            _selectedTorrentDetail = null;
            _selectedDetailErrorMessage = detailResult.ErrorMessage ?? "Selected torrent details unavailable.";

            if (!fromRefresh)
            {
                Feedback.Error(_selectedDetailErrorMessage);
            }

            _isLoadingSelectedDetail = false;
            return;
        }

        _selectedTorrentDetail = detailResult.Value;
        if (_selectedTorrentDetail is null)
        {
            _selectedDetailErrorMessage = "Selected torrent was not found.";
        }

        _isLoadingSelectedDetail = false;
    }

    private Task OnSearchChanged(string value)
    {
        _state.SearchText = value.Trim();
        PersistState();
        return Task.CompletedTask;
    }

    private Task OnStateFilterChanged(string value)
    {
        _state.PrimaryFilter = value;
        PersistState();
        return Task.CompletedTask;
    }

    private Task OnRowsPerPageChanged(int value)
    {
        _state.PageSize = value;
        PersistState();
        _actionMessage = $"Rows per page: {value}";
        _actionIsError = false;
        return Task.CompletedTask;
    }

    private Task OnAutoRefreshChanged(bool value)
    {
        _autoRefreshEnabled = value;
        _actionMessage = value ? "Auto refresh enabled." : "Auto refresh paused.";
        _actionIsError = false;
        return Task.CompletedTask;
    }

    private Task ClearFiltersAsync()
    {
        _state.SearchText = string.Empty;
        _state.PrimaryFilter = string.Empty;
        _state.SecondaryFilter = string.Empty;
        PersistState();
        Feedback.Info("Filters cleared.");
        _actionMessage = "Filters cleared.";
        _actionIsError = false;
        return Task.CompletedTask;
    }

    private Task OnCategoryFilterChanged(string value)
    {
        _state.SecondaryFilter = value;
        PersistState();
        return Task.CompletedTask;
    }

    private async Task PauseSelectedAsync()
    {
        await RunSelectedActionAsync("Pause", torrentId => Api.PauseAsync(torrentId));
    }

    private async Task ResumeSelectedAsync()
    {
        await RunSelectedActionAsync("Resume", torrentId => Api.ResumeAsync(torrentId));
    }

    private async Task RefreshMetadataSelectedAsync()
    {
        await RunSelectedActionAsync("Refresh metadata", torrentId => Api.RefreshMetadataAsync(torrentId));
    }

    private async Task ResetMetadataSelectedAsync()
    {
        await RunSelectedActionAsync("Reset metadata", torrentId => Api.ResetMetadataSessionAsync(torrentId));
    }

    private async Task RetryCallbackSelectedAsync()
    {
        await RunSelectedActionAsync("Retry callback", torrentId => Api.RetryCompletionCallbackAsync(torrentId));
    }

    private async Task RemoveSelectedAsync()
    {
        if (_selectedTorrentDetail is null)
        {
            return;
        }

        var confirmed = await Feedback.ConfirmAsync(
            "Remove Torrent",
            $"Remove '{_selectedTorrentDetail.Name}' from TorrentCore tracking?",
            confirmText: "Remove",
            cancelText: "Cancel"
        );

        if (!confirmed)
        {
            return;
        }

        await RunSelectedActionAsync(
            "Remove",
            torrentId => Api.RemoveAsync(torrentId, new RemoveTorrentRequest { DeleteData = false })
        );
    }

    private async Task DeleteSelectedDataAsync()
    {
        if (_selectedTorrentDetail is null)
        {
            return;
        }

        var confirmed = await Feedback.ConfirmAsync(
            "Delete Torrent Data",
            $"Delete '{_selectedTorrentDetail.Name}' and remove downloaded data from disk?",
            confirmText: "Delete Data",
            cancelText: "Cancel"
        );

        if (!confirmed)
        {
            return;
        }

        await RunSelectedActionAsync(
            "Delete data",
            torrentId => Api.RemoveAsync(torrentId, new RemoveTorrentRequest { DeleteData = true })
        );
    }

    private async Task RunSelectedActionAsync(
        string actionName,
        Func<Guid, Task<ServiceCallResult<TorrentActionResultDto>>> operation
    )
    {
        if (_selectedTorrentId is null || _isActingOnSelected)
        {
            return;
        }

        _isActingOnSelected = true;
        _actionMessage = null;
        _actionIsError = false;

        var result = await operation(_selectedTorrentId.Value);
        if (!result.IsSuccess)
        {
            _actionMessage = result.ErrorMessage ?? $"{actionName} failed.";
            _actionIsError = true;
            Feedback.Error(_actionMessage);
            _isActingOnSelected = false;
            return;
        }

        var processedAt = result.Value?.ProcessedAtUtc.LocalDateTime.ToString("g") ?? "now";
        _actionMessage = $"{actionName} completed at {processedAt}.";
        _actionIsError = false;
        Feedback.Success(_actionMessage);

        await LoadAsync(showSuccessToast: false, showLoadingState: false, fromAutoRefresh: false);
        _isActingOnSelected = false;
    }

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(AutoRefreshSeconds));

        while (await timer.WaitForNextTickAsync(cancellationToken))
        {
            if (_isDisposed || !_autoRefreshEnabled || _isRefreshing || _isActingOnSelected || _isLoadingSelectedDetail)
            {
                continue;
            }

            await InvokeAsync(
                async () =>
                {
                    if (_isDisposed)
                    {
                        return;
                    }

                    await LoadAsync(showSuccessToast: false, showLoadingState: false, fromAutoRefresh: true);
                    StateHasChanged();
                }
            );
        }
    }

    private void PersistState()
    {
        PageStateStore.Save(StateKey, _state);
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;

        if (_refreshLoopCts is not null)
        {
            await _refreshLoopCts.CancelAsync();
            _refreshLoopCts.Dispose();
        }

        if (_refreshLoopTask is not null)
        {
            try
            {
                await _refreshLoopTask;
            }
            catch (OperationCanceledException)
            {
            }
        }
    }

    private string GetTorrentRowClass(TorrentSummaryDto torrent, int rowNumber)
    {
        return _selectedTorrentId == torrent.TorrentId ? "operations-table-row--selected" : string.Empty;
    }

    private string BuildSelectionSummary()
    {
        if (_selectedTorrentDetail is null)
        {
            return "No active selection.";
        }

        return $"{_selectedTorrentDetail.Name} | {_selectedTorrentDetail.State} | {_selectedTorrentDetail.ProgressPercent:0.0}%";
    }

    private string GetActionMessageClass()
    {
        return _actionIsError ? "dashboard-panel-copy tc-error-text" : "dashboard-panel-copy";
    }

    private static string FormatCategory(string? categoryKey)
    {
        return string.IsNullOrWhiteSpace(categoryKey) ? "Uncategorized" : categoryKey;
    }

    private static string FormatRate(long bytesPerSecond)
    {
        return $"{bytesPerSecond / 1_000_000.0:0.00} MB/s";
    }

    private static string FormatSize(long bytes)
    {
        return $"{bytes / 1_000_000.0:0.00} MB";
    }

    private static string FormatNullableSize(long? bytes)
    {
        return bytes is null ? "Unknown" : FormatSize(bytes.Value);
    }

    private static string FormatTimestamp(DateTimeOffset timestamp)
    {
        return timestamp.LocalDateTime.ToString("g");
    }

    private static string FormatTimestamp(DateTimeOffset? timestamp)
    {
        return timestamp is null ? "N/A" : FormatTimestamp(timestamp.Value);
    }

    private static string FormatWaitReason(TorrentWaitReason? waitReason, int? queuePosition)
    {
        var waitReasonText = waitReason switch
        {
            TorrentWaitReason.PendingMetadataDispatch => "Pending metadata dispatch",
            TorrentWaitReason.WaitingForMetadataSlot => "Waiting for metadata slot",
            TorrentWaitReason.PendingDownloadDispatch => "Pending download dispatch",
            TorrentWaitReason.WaitingForDownloadSlot => "Waiting for download slot",
            TorrentWaitReason.PausedByOperator => "Paused by operator",
            TorrentWaitReason.BlockedByError => "Blocked by error",
            _ => string.Empty,
        };

        if (string.IsNullOrWhiteSpace(waitReasonText))
        {
            return "Not waiting";
        }

        return queuePosition is null ? waitReasonText : $"{waitReasonText} (#{queuePosition.Value})";
    }

    private static bool CanDeleteData(TorrentDetailDto torrent)
    {
        return torrent.State is TorrentState.ResolvingMetadata or TorrentState.Queued or TorrentState.Downloading or TorrentState.Error or TorrentState.Paused;
    }
}
